---
import { qingyangHubNodes, qingyangTimeline } from '../data/qingyang';

const scenePayload = {
  hubNodes: qingyangHubNodes,
  timeline: qingyangTimeline
};
---

<div class="qingyang-compute-scene" data-qingyang-scene data-qingyang-payload={JSON.stringify(scenePayload)} aria-hidden="true">
  <canvas data-qingyang-canvas></canvas>
  <div class="qingyang-compute-scene__overlay"></div>
</div>

<script>
  const qingyangRoots = document.querySelectorAll('[data-qingyang-scene]');

  if (qingyangRoots.length > 0) {
    import('three').then(async (THREE) => {
      const chinaGeoJson = await loadChinaGeoJson();
      qingyangRoots.forEach((root) => initQingyangScene(THREE, root, chinaGeoJson));
    });
  }

  async function loadChinaGeoJson() {
    try {
      const response = await fetch('/data/china-provinces.geojson');
      if (!response.ok) return null;
      return response.json();
    } catch {
      return null;
    }
  }

  function initQingyangScene(THREE, root, chinaGeoJson) {
    const canvas = root.querySelector('[data-qingyang-canvas]');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const payload = JSON.parse(root.dataset.qingyangPayload || '{}');
    const hubNodes = payload.hubNodes || [];
    const timeline = payload.timeline || [];
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
      preserveDrawingBuffer: true,
      powerPreference: 'high-performance'
    });
    renderer.setClearColor(0x000000, 0);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.7));

    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x06101e, 0.028);

    const camera = new THREE.PerspectiveCamera(39, 1, 0.1, 150);
    camera.position.set(2.7, 1.45, 17.8);

    const stage = new THREE.Group();
    const stageTilt = { x: -1.56, y: -0.018, z: 0 };
    stage.position.set(3.25, 0.18, 0.48);
    stage.rotation.set(stageTilt.x, stageTilt.y, stageTilt.z);
    stage.scale.setScalar(0.98);
    scene.add(stage);

    const gridLayer = new THREE.Group();
    const flowLayer = new THREE.Group();
    const nodeLayer = new THREE.Group();
    const cardLayer = new THREE.Group();
    const towerLayer = new THREE.Group();
    stage.add(gridLayer, flowLayer, nodeLayer, cardLayer, towerLayer);

    const positionedHubNodes = hubNodes.map((node) => ({ ...node, ...projectHubNode(node) }));
    createDataTerrain(THREE, gridLayer, chinaGeoJson, positionedHubNodes);

    const nodeObjects = positionedHubNodes.map((node) => {
      const object = createComputeNode(THREE, node, Boolean(node.isCore));
      object.group.position.set(node.x, node.isCore ? 0.55 : 0.36, node.z);
      nodeLayer.add(object.group);
      return { ...object, data: node };
    });
    cardLayer.add(createHubCards(THREE, positionedHubNodes));

    const qingyang = nodeObjects.find((node) => node.data.isCore) || nodeObjects[0];
    const qingyangPosition = new THREE.Vector3(qingyang.data.x, 0.78, qingyang.data.z);

    const flowCurves = positionedHubNodes
      .filter((node) => !node.isCore)
      .map((node, index) => {
      const start = new THREE.Vector3(node.x, 0.62, node.z);
      const end = qingyangPosition.clone();
      const middle = new THREE.Vector3(
        (node.x + qingyang.data.x) * 0.5,
        1.72 + (index % 5) * 0.2,
        (node.z + qingyang.data.z) * 0.5 + Math.sin(index) * 0.5
      );
      const curve = new THREE.CatmullRomCurve3([start, middle, end]);
      const color = Number.parseInt(node.color.replace('#', '0x'));
      const line = new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(curve.getPoints(120)),
        new THREE.LineBasicMaterial({
          color,
          transparent: true,
          opacity: node.name === '张家口' || node.name === '长三角' || node.name === '韶关' ? 0.72 : 0.46,
          depthWrite: false,
          blending: THREE.AdditiveBlending
        })
      );
      flowLayer.add(line);
      flowLayer.add(createFlowTube(THREE, curve, color, node.name === '庆阳' ? 0.03 : 0.018));
      return { curve, line, color: node.color, index };
    });

    const particles = createFlowParticles(THREE, flowCurves, 188);
    particles.forEach((particle) => flowLayer.add(particle.mesh));

    const growthTower = createGrowthTower(THREE, timeline);
    growthTower.group.position.set(qingyang.data.x, 0.15, qingyang.data.z);
    towerLayer.add(growthTower.group);

    const rings = createEnergyRings(THREE);
    rings.position.set(qingyang.data.x, 0.42, qingyang.data.z);
    nodeLayer.add(rings);

    const stars = createQingyangStars(THREE);
    scene.add(stars);

    let frameId = 0;
    const clock = new THREE.Clock();

    function resize() {
      const rect = root.getBoundingClientRect();
      const width = Math.max(1, Math.floor(rect.width));
      const height = Math.max(1, Math.floor(rect.height));
      renderer.setSize(width, height, false);
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
    }

    function render() {
      const elapsed = clock.getElapsedTime();
      stage.rotation.x = stageTilt.x + Math.sin(elapsed * 0.045) * 0.01;
      stage.rotation.y = stageTilt.y + Math.sin(elapsed * 0.07) * 0.032;
      gridLayer.position.x = Math.sin(elapsed * 0.18) * 0.16;
      stars.rotation.y = elapsed * 0.015;
      nodeObjects.forEach((node, index) => node.pulse(elapsed + index * 0.55, Boolean(node.data.isCore)));
      growthTower.animate(elapsed);
      rings.children.forEach((ring, index) => {
        ring.rotation.z += 0.004 + index * 0.0012;
        ring.material.opacity = 0.22 + Math.sin(elapsed * 1.2 + index) * 0.06;
      });

      particles.forEach((particle) => {
        const t = (elapsed * particle.speed + particle.offset) % 1;
        particle.mesh.position.copy(particle.curve.getPointAt(t));
        particle.mesh.scale.setScalar(particle.baseScale * (0.75 + Math.sin(t * Math.PI * 2) * 0.28));
      });

      camera.lookAt(1.62, -0.02, 1.78);
      renderer.render(scene, camera);
      if (!prefersReducedMotion.matches) frameId = window.requestAnimationFrame(render);
    }

    const observer = new ResizeObserver(resize);
    observer.observe(root);
    resize();

    if (prefersReducedMotion.matches) {
      renderer.render(scene, camera);
    } else {
      frameId = window.requestAnimationFrame(render);
    }

    prefersReducedMotion.addEventListener?.('change', () => {
      window.cancelAnimationFrame(frameId);
      clock.start();
      resize();
      render();
    });

    window.addEventListener('pagehide', () => {
      observer.disconnect();
      window.cancelAnimationFrame(frameId);
      renderer.dispose();
      scene.traverse((object) => {
        if (object.geometry) object.geometry.dispose();
        if (object.material) {
          const materials = Array.isArray(object.material) ? object.material : [object.material];
          materials.forEach((material) => {
            if (material.map) material.map.dispose();
            material.dispose();
          });
        }
      });
    }, { once: true });
  }

  const CHINA_MAP_BOUNDS = {
    minLon: 73.25,
    maxLon: 135.25,
    minLat: 17.6,
    maxLat: 53.8
  };
  const CHINA_MAP_SIZE = { width: 10.8, height: 6.3 };

  function createDataTerrain(THREE, group, chinaGeoJson, hubNodes) {
    const chinaMap = createChinaMap(THREE, chinaGeoJson, hubNodes);
    group.add(chinaMap);

    const grid = new THREE.GridHelper(18, 28, 0x42d9e8, 0x42d9e8);
    grid.position.y = -2.6;
    grid.material.transparent = true;
    grid.material.opacity = 0.12;
    group.add(grid);

    const gold = new THREE.LineBasicMaterial({ color: 0xd7a43a, transparent: true, opacity: 0.18 });
    const cyan = new THREE.LineBasicMaterial({ color: 0x55dbea, transparent: true, opacity: 0.16 });
    for (let row = 0; row < 14; row += 1) {
      const points = [];
      const z = -4.7 + row * 0.7;
      for (let col = 0; col < 96; col += 1) {
        const x = -6.4 + col * 0.14;
        const y = -2.45 + Math.sin(col * 0.12 + row * 0.7) * 0.18 + Math.cos(col * 0.04) * 0.12;
        points.push(new THREE.Vector3(x, y, z + Math.sin(col * 0.05 + row) * 0.22));
      }
      group.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(points), row % 5 === 0 ? gold : cyan));
    }
  }

  function projectHubNode(node) {
    if (typeof node.lon === 'number' && typeof node.lat === 'number') {
      const [x, z] = projectChinaCoordinate(node.lon, node.lat);
      return { x, z };
    }
    return { x: node.x || 0, z: node.z || 0 };
  }

  function projectChinaCoordinate(lon, lat) {
    const xRatio = (lon - CHINA_MAP_BOUNDS.minLon) / (CHINA_MAP_BOUNDS.maxLon - CHINA_MAP_BOUNDS.minLon);
    const zRatio = (lat - CHINA_MAP_BOUNDS.minLat) / (CHINA_MAP_BOUNDS.maxLat - CHINA_MAP_BOUNDS.minLat);
    return [
      (xRatio - 0.5) * CHINA_MAP_SIZE.width,
      (zRatio - 0.5) * CHINA_MAP_SIZE.height
    ];
  }

  function createChinaMap(THREE, chinaGeoJson, hubNodes) {
    const group = new THREE.Group();
    if (!chinaGeoJson?.features?.length) return group;

    const provinceHighlights = createProvinceHighlightMap(hubNodes);
    const mutedRegionColors = [0x0f4050, 0x123f55, 0x173d61, 0x0f4d55, 0x184451];
    const lineMaterial = new THREE.LineBasicMaterial({
      color: 0xa9f8ff,
      transparent: true,
      opacity: 0.22,
      depthWrite: false,
      blending: THREE.AdditiveBlending
    });

    chinaGeoJson.features.forEach((feature, featureIndex) => {
      if (feature.geometry?.type === 'MultiPolygon' || feature.geometry?.type === 'Polygon') {
        const provinceName = feature.properties?.name || '';
        const highlightColor = provinceHighlights.get(provinceName);
        const provinceColor = highlightColor || mutedRegionColors[featureIndex % mutedRegionColors.length];
        const provinceOpacity = highlightColor ? 0.72 : 0.16;
        const polygons = feature.geometry.type === 'Polygon' ? [feature.geometry.coordinates] : feature.geometry.coordinates;
        polygons.forEach((polygon, polygonIndex) => {
          if (!isMainMapPolygon(polygon)) return;
          const mesh = createProvinceMesh(THREE, polygon, provinceColor, provinceOpacity, featureIndex, polygonIndex);
          if (mesh) group.add(mesh);
          polygon.forEach((ring, ringIndex) => {
            const points = projectRingToVectors(THREE, ring, -2.08 + ringIndex * 0.002);
            if (points.length > 2) group.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(points), lineMaterial));
          });
          if (highlightColor && polygonIndex < 3) {
            const ring = projectRingToShapePoints(polygon[0]);
            if (ring.length > 2) group.add(createMapTube(THREE, ring, highlightColor, -2.0 + polygonIndex * 0.008, 0.02, 0.68));
          }
        });
      }
      if (feature.geometry?.type === 'MultiLineString') {
        feature.geometry.coordinates.forEach((line, lineIndex) => {
          const points = projectRingToVectors(THREE, line, -2.04 + lineIndex * 0.002).filter((point) => point.z > -3.05);
          if (points.length > 2) group.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(points), lineMaterial));
        });
      }
    });

    const glowLines = collectProvinceOuterRings(chinaGeoJson).slice(0, 46);
    glowLines.forEach((ring, index) => {
      group.add(createMapTube(THREE, ring, index % 3 === 0 ? 0xf3d98a : 0x98fbff, -2.02 + index * 0.0008, index % 3 === 0 ? 0.012 : 0.008, 0.2));
    });

    return group;
  }

  function createMapShape(THREE, points) {
    const shape = new THREE.Shape();
    points.forEach(([x, z], index) => {
      if (index === 0) shape.moveTo(x, z);
      else shape.lineTo(x, z);
    });
    return shape;
  }

  function createProvinceHighlightMap(hubNodes) {
    const highlights = new Map();
    hubNodes.forEach((node) => {
      const color = Number.parseInt(node.color.replace('#', '0x'));
      (node.provinces || []).forEach((province) => {
        if (!highlights.has(province)) highlights.set(province, color);
      });
    });
    return highlights;
  }

  function createProvinceMesh(THREE, polygon, color, opacity, featureIndex, polygonIndex) {
    const outer = projectRingToShapePoints(polygon[0]);
    if (outer.length < 3) return null;
    const shape = createMapShape(THREE, outer);
    polygon.slice(1).forEach((hole) => {
      const points = projectRingToShapePoints(hole);
      if (points.length < 3) return;
      const path = new THREE.Path();
      points.forEach(([x, z], index) => {
        if (index === 0) path.moveTo(x, z);
        else path.lineTo(x, z);
      });
      shape.holes.push(path);
    });
    const mesh = new THREE.Mesh(
      new THREE.ShapeGeometry(shape),
      new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity,
        side: THREE.DoubleSide,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
    mesh.rotation.x = Math.PI / 2;
    mesh.position.y = -2.32 + featureIndex * 0.002 + polygonIndex * 0.0004;
    return mesh;
  }

  function projectRingToShapePoints(ring) {
    return ring
      .filter(([lon, lat]) => lat >= CHINA_MAP_BOUNDS.minLat)
      .map(([lon, lat]) => projectChinaCoordinate(lon, lat));
  }

  function projectRingToVectors(THREE, ring, y) {
    return ring
      .filter(([lon, lat]) => lat >= CHINA_MAP_BOUNDS.minLat)
      .map(([lon, lat]) => {
        const [x, z] = projectChinaCoordinate(lon, lat);
        return new THREE.Vector3(x, y, z);
      });
  }

  function isMainMapPolygon(polygon) {
    const outer = polygon[0] || [];
    return outer.some(([, lat]) => lat >= CHINA_MAP_BOUNDS.minLat);
  }

  function collectProvinceOuterRings(chinaGeoJson) {
    const rings = [];
    chinaGeoJson.features.forEach((feature) => {
      if (feature.geometry?.type !== 'MultiPolygon' && feature.geometry?.type !== 'Polygon') return;
      const polygons = feature.geometry.type === 'Polygon' ? [feature.geometry.coordinates] : feature.geometry.coordinates;
      polygons.forEach((polygon) => {
        if (isMainMapPolygon(polygon)) rings.push(projectRingToShapePoints(polygon[0]));
      });
    });
    return rings.sort((a, b) => b.length - a.length);
  }

  function createMapTube(THREE, points, color, y, radius, opacity) {
    const curve = new THREE.CatmullRomCurve3(points.map(([x, z]) => new THREE.Vector3(x, y, z)));
    const geometry = new THREE.TubeGeometry(curve, Math.max(48, points.length * 12), radius, 8, false);
    return new THREE.Mesh(
      geometry,
      new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
  }

  function createFlowTube(THREE, curve, color, radius) {
    return new THREE.Mesh(
      new THREE.TubeGeometry(curve, 112, radius, 8, false),
      new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity: 0.18,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
  }

  function createComputeNode(THREE, node, isCore) {
    const group = new THREE.Group();
    const color = Number.parseInt(node.color.replace('#', '0x'));
    const core = new THREE.Mesh(
      new THREE.IcosahedronGeometry(isCore ? 0.5 : 0.28, isCore ? 2 : 1),
      new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity: isCore ? 0.9 : 0.7,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
    group.add(core);

    const ring = new THREE.Mesh(
      new THREE.TorusGeometry(isCore ? 0.95 : 0.56, isCore ? 0.02 : 0.013, 16, 100),
      new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity: isCore ? 0.48 : 0.32,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
    ring.rotation.x = Math.PI / 2.35;
    group.add(ring);

    return {
      group,
      pulse(elapsed, coreNode) {
        const pulse = 1 + Math.sin(elapsed * (coreNode ? 2.1 : 1.6)) * (coreNode ? 0.055 : 0.035);
        core.scale.setScalar(pulse);
        ring.rotation.z += coreNode ? 0.009 : 0.004;
        ring.material.opacity = (coreNode ? 0.42 : 0.26) + Math.sin(elapsed * 1.4) * 0.06;
      }
    };
  }

  function createHubCards(THREE, nodes) {
    const group = new THREE.Group();
    nodes.forEach((node, index) => {
      const color = Number.parseInt(node.color.replace('#', '0x'));
      const cardX = node.cardX ?? node.x;
      const cardZ = node.cardZ ?? node.z;
      const cardY = node.isCore ? 1.58 : 1.3;
      const nodePoint = new THREE.Vector3(node.x, node.isCore ? 0.82 : 0.62, node.z);
      const cardPoint = new THREE.Vector3(cardX, cardY, cardZ);
      const elbow = new THREE.Vector3(
        node.x + (cardX - node.x) * 0.42,
        cardY - 0.18,
        node.z + (cardZ - node.z) * 0.42
      );

      const connector = new THREE.Line(
        new THREE.BufferGeometry().setFromPoints([nodePoint, elbow, cardPoint]),
        new THREE.LineBasicMaterial({
          color,
          transparent: true,
          opacity: node.isCore ? 0.72 : 0.46,
          depthWrite: false,
          blending: THREE.AdditiveBlending
        })
      );
      group.add(connector);

      const dot = new THREE.Mesh(
        new THREE.SphereGeometry(node.isCore ? 0.08 : 0.055, 10, 10),
        new THREE.MeshBasicMaterial({
          color,
          transparent: true,
          opacity: 0.94,
          depthWrite: false,
          blending: THREE.AdditiveBlending
        })
      );
      dot.position.copy(cardPoint);
      group.add(dot);

      const card = new THREE.Sprite(
        new THREE.SpriteMaterial({
          map: createHubCardTexture(THREE, node, color, index + 1),
          transparent: true,
          opacity: node.isCore ? 0.96 : 0.86,
          depthWrite: false
        })
      );
      card.position.set(cardX, cardY + 0.05, cardZ);
      card.scale.set(node.isCore ? 2.25 : 1.92, node.isCore ? 0.82 : 0.68, 1);
      group.add(card);
    });
    return group;
  }

  function createGrowthTower(THREE, timeline) {
    const group = new THREE.Group();
    const bars = [];
    const heights = [0.9, 1.55, 2.35];
    timeline.forEach((item, index) => {
      const height = heights[index] || 1.2;
      const material = new THREE.MeshBasicMaterial({
        color: index === timeline.length - 1 ? 0xf3d98a : 0x7de3ef,
        transparent: true,
        opacity: 0.22,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      });
      const bar = new THREE.Mesh(new THREE.CylinderGeometry(0.19, 0.24, height, 32), material);
      bar.position.set(-0.72 + index * 0.72, -1.72 + height / 2, -0.55);
      group.add(bar);
      bars.push(bar);

      const label = new THREE.Sprite(
        new THREE.SpriteMaterial({
          map: createTimelineTexture(THREE, item.month, item.value, index === timeline.length - 1 ? 0xf3d98a : 0x7de3ef),
          transparent: true,
          opacity: 0.84,
          depthWrite: false
        })
      );
      label.position.set(bar.position.x, -1.25 + height, -0.48);
      label.scale.set(1.2, 0.5, 1);
      group.add(label);
    });

    return {
      group,
      animate(elapsed) {
        bars.forEach((bar, index) => {
          bar.material.opacity = 0.18 + Math.sin(elapsed * 1.2 + index) * 0.05;
        });
      }
    };
  }

  function createComputeLegend(THREE) {
    const group = new THREE.Group();
    const face = new THREE.Mesh(
      new THREE.PlaneGeometry(3.7, 1.45),
      new THREE.MeshBasicMaterial({
        map: createLegendTexture(THREE),
        transparent: true,
        opacity: 0.82,
        depthWrite: false
      })
    );
    group.add(face);

    const edges = [
      { x: -1.94, y: 0.76, w: 0.55, h: 0.02 },
      { x: 1.42, y: -0.76, w: 0.55, h: 0.02 },
      { x: -1.94, y: -0.48, w: 0.02, h: 0.42 },
      { x: 1.94, y: 0.48, w: 0.02, h: 0.42 }
    ];
    edges.forEach((edge) => {
      const mesh = new THREE.Mesh(
        new THREE.PlaneGeometry(edge.w, edge.h),
        new THREE.MeshBasicMaterial({ color: 0x7de3ef, transparent: true, opacity: 0.7, depthWrite: false, blending: THREE.AdditiveBlending })
      );
      mesh.position.set(edge.x, edge.y, 0.04);
      group.add(mesh);
    });
    return group;
  }

  function createEnergyRings(THREE) {
    const group = new THREE.Group();
    [1.32, 1.95, 2.58].forEach((radius, index) => {
      const ring = new THREE.Mesh(
        new THREE.TorusGeometry(radius, 0.018, 16, 140),
        new THREE.MeshBasicMaterial({
          color: index === 1 ? 0xf3d98a : 0x7de3ef,
          transparent: true,
          opacity: 0.16,
          depthWrite: false,
          blending: THREE.AdditiveBlending
        })
      );
      ring.rotation.x = Math.PI / 2.6 + index * 0.2;
      ring.rotation.y = index * 0.38;
      group.add(ring);
    });
    return group;
  }

  function createFlowParticles(THREE, curves, count) {
    const particles = [];
    const geometry = new THREE.SphereGeometry(0.064, 12, 12);
    for (let index = 0; index < count; index += 1) {
      const flow = curves[index % curves.length];
      const mesh = new THREE.Mesh(
        geometry,
        new THREE.MeshBasicMaterial({
          color: Number.parseInt(flow.color.replace('#', '0x')),
          transparent: true,
          opacity: 0.86,
          depthWrite: false,
          blending: THREE.AdditiveBlending
        })
      );
      particles.push({
        mesh,
        curve: flow.curve,
        offset: index / count,
        speed: 0.04 + (index % 9) * 0.006,
        baseScale: 0.8 + (index % 6) * 0.08
      });
    }
    return particles;
  }

  function createNodeLabelTexture(THREE, name, subtitle, color, isCore) {
    const canvas = document.createElement('canvas');
    canvas.width = 520;
    canvas.height = 170;
    const ctx = canvas.getContext('2d');
    const accent = `#${color.toString(16).padStart(6, '0')}`;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = 'rgba(6, 16, 30, 0.72)';
    ctx.strokeStyle = isCore ? 'rgba(243, 217, 138, 0.72)' : 'rgba(125, 227, 239, 0.38)';
    ctx.lineWidth = 3;
    roundRect(ctx, 10, 12, 500, 146, 18);
    ctx.fill();
    ctx.stroke();
    ctx.fillStyle = accent;
    ctx.font = '900 28px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(isCore ? '核心枢纽' : '数据中心集群', 34, 55);
    ctx.fillStyle = '#ffffff';
    ctx.font = isCore ? '950 48px "PingFang SC", "Microsoft YaHei", sans-serif' : '900 40px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(name, 34, 110);
    ctx.fillStyle = 'rgba(255, 255, 255, 0.62)';
    ctx.font = '750 22px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(subtitle, 34, 140);
    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    return texture;
  }

  function createHubCardTexture(THREE, node, color, order) {
    const canvas = document.createElement('canvas');
    canvas.width = 620;
    canvas.height = 220;
    const ctx = canvas.getContext('2d');
    const accent = `#${color.toString(16).padStart(6, '0')}`;
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    const gradient = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
    gradient.addColorStop(0, 'rgba(5, 16, 29, 0.9)');
    gradient.addColorStop(0.55, 'rgba(10, 42, 54, 0.72)');
    gradient.addColorStop(1, 'rgba(4, 10, 20, 0.84)');
    ctx.fillStyle = gradient;
    roundRect(ctx, 14, 16, 592, 188, 22);
    ctx.fill();

    ctx.strokeStyle = node.isCore ? 'rgba(243, 217, 138, 0.78)' : `${accent}aa`;
    ctx.lineWidth = node.isCore ? 4 : 3;
    ctx.stroke();

    ctx.fillStyle = accent;
    ctx.font = '900 26px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(String(order).padStart(2, '0'), 38, 62);

    ctx.fillStyle = '#ffffff';
    ctx.font = node.isCore ? '950 48px "PingFang SC", "Microsoft YaHei", sans-serif' : '900 42px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(node.name, 118, 80);

    ctx.fillStyle = accent;
    ctx.font = '850 25px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText((node.provinces || []).slice(0, 2).join(' · '), 118, 122);

    ctx.fillStyle = 'rgba(255, 255, 255, 0.66)';
    ctx.font = '760 25px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(node.subtitle, 118, 164);

    ctx.strokeStyle = `${accent}80`;
    ctx.beginPath();
    ctx.moveTo(38, 92);
    ctx.lineTo(82, 92);
    ctx.stroke();

    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    return texture;
  }

  function createTimelineTexture(THREE, month, value, color) {
    const canvas = document.createElement('canvas');
    canvas.width = 360;
    canvas.height = 150;
    const ctx = canvas.getContext('2d');
    const accent = `#${color.toString(16).padStart(6, '0')}`;
    ctx.fillStyle = 'rgba(6, 16, 30, 0.66)';
    ctx.strokeStyle = 'rgba(125, 227, 239, 0.34)';
    ctx.lineWidth = 2;
    roundRect(ctx, 8, 10, 344, 130, 18);
    ctx.fill();
    ctx.stroke();
    ctx.fillStyle = accent;
    ctx.font = '900 25px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(month, 28, 50);
    ctx.fillStyle = '#ffffff';
    ctx.font = '950 42px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(value, 28, 102);
    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    return texture;
  }

  function createLegendTexture(THREE) {
    const canvas = document.createElement('canvas');
    canvas.width = 900;
    canvas.height = 360;
    const ctx = canvas.getContext('2d');
    const gradient = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
    gradient.addColorStop(0, 'rgba(9, 26, 42, 0.9)');
    gradient.addColorStop(0.58, 'rgba(10, 52, 66, 0.62)');
    gradient.addColorStop(1, 'rgba(4, 12, 24, 0.85)');
    ctx.fillStyle = gradient;
    roundRect(ctx, 20, 20, 860, 320, 28);
    ctx.fill();
    ctx.strokeStyle = 'rgba(125, 227, 239, 0.58)';
    ctx.lineWidth = 3;
    ctx.stroke();

    ctx.fillStyle = '#7de3ef';
    ctx.font = '900 30px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText('全国一体化算力网络', 58, 82);
    ctx.fillStyle = '#ffffff';
    ctx.font = '950 54px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText('十个数据中心集群', 58, 158);
    ctx.fillStyle = 'rgba(255, 255, 255, 0.54)';
    ctx.font = '850 33px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText('东部需求穿梭至西部绿色算力', 58, 214);

    ctx.fillStyle = '#f3d98a';
    ctx.font = '950 42px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText('庆阳 14.2万P', 58, 292);
    ctx.fillStyle = 'rgba(255, 255, 255, 0.58)';
    ctx.font = '850 25px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText('算力规模持续跃升', 365, 292);

    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    return texture;
  }

  function createQingyangStars(THREE) {
    const geometry = new THREE.BufferGeometry();
    const positions = [];
    for (let index = 0; index < 420; index += 1) {
      positions.push((Math.random() - 0.5) * 34, Math.random() * 18 - 2.2, (Math.random() - 0.5) * 24);
    }
    geometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
    return new THREE.Points(
      geometry,
      new THREE.PointsMaterial({
        color: 0x7de3ef,
        size: 0.04,
        transparent: true,
        opacity: 0.5
      })
    );
  }

  function roundRect(ctx, x, y, width, height, radius) {
    ctx.beginPath();
    ctx.moveTo(x + radius, y);
    ctx.arcTo(x + width, y, x + width, y + height, radius);
    ctx.arcTo(x + width, y + height, x, y + height, radius);
    ctx.arcTo(x, y + height, x, y, radius);
    ctx.arcTo(x, y, x + width, y, radius);
    ctx.closePath();
  }
</script>
