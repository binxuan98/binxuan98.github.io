---
import { qingyangHubNodes, qingyangTimeline } from '../data/qingyang';

const scenePayload = {
  hubNodes: qingyangHubNodes,
  timeline: qingyangTimeline
};
---

<div class="qingyang-compute-scene" data-qingyang-scene data-qingyang-payload={JSON.stringify(scenePayload)} aria-hidden="true">
  <canvas data-qingyang-canvas></canvas>
  <div class="qingyang-compute-scene__overlay"></div>
</div>

<script>
  const qingyangRoots = document.querySelectorAll('[data-qingyang-scene]');

  if (qingyangRoots.length > 0) {
    import('three').then((THREE) => {
      qingyangRoots.forEach((root) => initQingyangScene(THREE, root));
    });
  }

  function initQingyangScene(THREE, root) {
    const canvas = root.querySelector('[data-qingyang-canvas]');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const payload = JSON.parse(root.dataset.qingyangPayload || '{}');
    const hubNodes = payload.hubNodes || [];
    const timeline = payload.timeline || [];
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
      preserveDrawingBuffer: true,
      powerPreference: 'high-performance'
    });
    renderer.setClearColor(0x000000, 0);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.7));

    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x06101e, 0.028);

    const camera = new THREE.PerspectiveCamera(41, 1, 0.1, 150);
    camera.position.set(2.5, 1.95, 17.4);

    const stage = new THREE.Group();
    const stageTilt = { x: -1.36, y: -0.12, z: 0.012 };
    stage.position.set(3.35, 0.32, 0.32);
    stage.rotation.set(stageTilt.x, stageTilt.y, stageTilt.z);
    stage.scale.setScalar(1.02);
    scene.add(stage);

    const gridLayer = new THREE.Group();
    const flowLayer = new THREE.Group();
    const nodeLayer = new THREE.Group();
    const towerLayer = new THREE.Group();
    stage.add(gridLayer, flowLayer, nodeLayer, towerLayer);

    createDataTerrain(THREE, gridLayer);

    const nodeObjects = hubNodes.map((node) => {
      const object = createComputeNode(THREE, node, Boolean(node.isCore));
      object.group.position.set(node.x, node.isCore ? 0.55 : 0.36, node.z);
      nodeLayer.add(object.group);
      return { ...object, data: node };
    });
    const qingyang = nodeObjects.find((node) => node.data.isCore) || nodeObjects[0];
    const qingyangPosition = new THREE.Vector3(qingyang.data.x, 0.78, qingyang.data.z);

    const flowCurves = hubNodes
      .filter((node) => !node.isCore)
      .map((node, index) => {
      const start = new THREE.Vector3(node.x, 0.62, node.z);
      const end = qingyangPosition.clone();
      const middle = new THREE.Vector3(
        (node.x + qingyang.data.x) * 0.5,
        2.2 + (index % 5) * 0.28,
        (node.z + qingyang.data.z) * 0.5 + Math.sin(index) * 0.5
      );
      const curve = new THREE.CatmullRomCurve3([start, middle, end]);
      const line = new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(curve.getPoints(120)),
        new THREE.LineBasicMaterial({
          color: Number.parseInt(node.color.replace('#', '0x')),
          transparent: true,
          opacity: node.name === '张家口' || node.name === '长三角' || node.name === '韶关' ? 0.48 : 0.24,
          depthWrite: false,
          blending: THREE.AdditiveBlending
        })
      );
      flowLayer.add(line);
      return { curve, line, color: node.color, index };
    });

    const particles = createFlowParticles(THREE, flowCurves, 188);
    particles.forEach((particle) => flowLayer.add(particle.mesh));

    const growthTower = createGrowthTower(THREE, timeline);
    growthTower.group.position.set(qingyang.data.x, 0.15, qingyang.data.z);
    towerLayer.add(growthTower.group);

    const legend = createComputeLegend(THREE);
    legend.position.set(4.95, 3.05, 3.58);
    legend.rotation.set(-0.04, -0.28, 0.01);
    scene.add(legend);

    const rings = createEnergyRings(THREE);
    rings.position.set(qingyang.data.x, 0.42, qingyang.data.z);
    nodeLayer.add(rings);

    const stars = createQingyangStars(THREE);
    scene.add(stars);

    let frameId = 0;
    const clock = new THREE.Clock();

    function resize() {
      const rect = root.getBoundingClientRect();
      const width = Math.max(1, Math.floor(rect.width));
      const height = Math.max(1, Math.floor(rect.height));
      renderer.setSize(width, height, false);
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
    }

    function render() {
      const elapsed = clock.getElapsedTime();
      stage.rotation.x = stageTilt.x + Math.sin(elapsed * 0.045) * 0.01;
      stage.rotation.y = stageTilt.y + Math.sin(elapsed * 0.07) * 0.032;
      gridLayer.position.x = Math.sin(elapsed * 0.18) * 0.16;
      stars.rotation.y = elapsed * 0.015;
      nodeObjects.forEach((node, index) => node.pulse(elapsed + index * 0.55, Boolean(node.data.isCore)));
      growthTower.animate(elapsed);
      legend.position.y = 3.05 + Math.sin(elapsed * 0.5) * 0.05;
      legend.rotation.y = -0.28 + Math.sin(elapsed * 0.2) * 0.014;
      rings.children.forEach((ring, index) => {
        ring.rotation.z += 0.004 + index * 0.0012;
        ring.material.opacity = 0.22 + Math.sin(elapsed * 1.2 + index) * 0.06;
      });

      particles.forEach((particle) => {
        const t = (elapsed * particle.speed + particle.offset) % 1;
        particle.mesh.position.copy(particle.curve.getPointAt(t));
        particle.mesh.scale.setScalar(particle.baseScale * (0.75 + Math.sin(t * Math.PI * 2) * 0.28));
      });

      camera.lookAt(1.38, 0.06, 1.68);
      renderer.render(scene, camera);
      if (!prefersReducedMotion.matches) frameId = window.requestAnimationFrame(render);
    }

    const observer = new ResizeObserver(resize);
    observer.observe(root);
    resize();

    if (prefersReducedMotion.matches) {
      renderer.render(scene, camera);
    } else {
      frameId = window.requestAnimationFrame(render);
    }

    prefersReducedMotion.addEventListener?.('change', () => {
      window.cancelAnimationFrame(frameId);
      clock.start();
      resize();
      render();
    });

    window.addEventListener('pagehide', () => {
      observer.disconnect();
      window.cancelAnimationFrame(frameId);
      renderer.dispose();
      scene.traverse((object) => {
        if (object.geometry) object.geometry.dispose();
        if (object.material) {
          const materials = Array.isArray(object.material) ? object.material : [object.material];
          materials.forEach((material) => {
            if (material.map) material.map.dispose();
            material.dispose();
          });
        }
      });
    }, { once: true });
  }

  function createDataTerrain(THREE, group) {
    const chinaMap = createChinaMap(THREE);
    group.add(chinaMap);

    const grid = new THREE.GridHelper(18, 28, 0x42d9e8, 0x42d9e8);
    grid.position.y = -2.6;
    grid.material.transparent = true;
    grid.material.opacity = 0.12;
    group.add(grid);

    const gold = new THREE.LineBasicMaterial({ color: 0xd7a43a, transparent: true, opacity: 0.18 });
    const cyan = new THREE.LineBasicMaterial({ color: 0x55dbea, transparent: true, opacity: 0.16 });
    for (let row = 0; row < 14; row += 1) {
      const points = [];
      const z = -4.7 + row * 0.7;
      for (let col = 0; col < 96; col += 1) {
        const x = -6.4 + col * 0.14;
        const y = -2.45 + Math.sin(col * 0.12 + row * 0.7) * 0.18 + Math.cos(col * 0.04) * 0.12;
        points.push(new THREE.Vector3(x, y, z + Math.sin(col * 0.05 + row) * 0.22));
      }
      group.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(points), row % 5 === 0 ? gold : cyan));
    }
  }

  function createChinaMap(THREE) {
    const group = new THREE.Group();
    const outline = [
      [-6.55, 0.55], [-6.1, 1.32], [-5.15, 1.95], [-4.2, 2.54],
      [-3.15, 2.22], [-2.08, 2.74], [-0.82, 2.32], [0.26, 2.64],
      [1.36, 2.12], [2.38, 1.95], [3.06, 1.34], [4.24, 1.1],
      [5.38, 0.24], [4.92, -0.58], [4.0, -0.72], [3.78, -1.48],
      [3.15, -2.22], [2.22, -2.06], [1.54, -2.52], [0.72, -2.04],
      [-0.26, -2.28], [-0.98, -1.72], [-1.92, -1.94], [-2.82, -1.42],
      [-3.72, -1.58], [-4.6, -0.98], [-5.64, -1.02], [-6.28, -0.32],
      [-6.55, 0.55]
    ];
    const shape = createMapShape(THREE, outline);

    const fill = new THREE.Mesh(
      new THREE.ShapeGeometry(shape),
      new THREE.MeshBasicMaterial({
        color: 0x0d3c4e,
        transparent: true,
        opacity: 0.58,
        side: THREE.DoubleSide,
        depthWrite: false
      })
    );
    fill.rotation.x = -Math.PI / 2;
    fill.position.y = -2.32;
    group.add(fill);

    const regions = [
      { color: 0x1d6f92, points: [[-6.25, 0.35], [-5.75, 1.25], [-4.72, 1.75], [-3.6, 1.55], [-3.28, 0.62], [-4.2, -0.28], [-5.45, -0.55], [-6.15, -0.12], [-6.25, 0.35]] },
      { color: 0x2a8c77, points: [[-4.72, 1.75], [-3.2, 2.18], [-2.0, 1.86], [-1.5, 0.92], [-3.28, 0.62], [-3.6, 1.55], [-4.72, 1.75]] },
      { color: 0x6b84c7, points: [[-2.0, 1.86], [-0.82, 2.32], [0.62, 2.38], [1.52, 1.82], [0.92, 1.02], [-0.82, 0.82], [-1.5, 0.92], [-2.0, 1.86]] },
      { color: 0x2d9eb5, points: [[1.52, 1.82], [3.06, 1.34], [4.25, 1.0], [4.74, 0.36], [4.1, -0.28], [2.45, 0.08], [0.92, 1.02], [1.52, 1.82]] },
      { color: 0xcaa45e, points: [[-3.28, 0.62], [-1.5, 0.92], [-0.82, 0.82], [0.92, 1.02], [2.45, 0.08], [1.58, -0.64], [-0.32, -0.72], [-2.18, -0.9], [-3.28, 0.62]] },
      { color: 0x1f7e64, points: [[-5.45, -0.55], [-4.2, -0.28], [-3.28, 0.62], [-2.18, -0.9], [-1.36, -1.78], [-2.82, -1.42], [-3.72, -1.58], [-4.6, -0.98], [-5.45, -0.55]] },
      { color: 0x4c72b7, points: [[-2.18, -0.9], [-0.32, -0.72], [0.82, -1.88], [-0.26, -2.28], [-0.98, -1.72], [-1.36, -1.78], [-2.18, -0.9]] },
      { color: 0x2b9c8c, points: [[-0.32, -0.72], [1.58, -0.64], [0.82, -1.88], [-0.26, -2.28], [-0.32, -0.72]] },
      { color: 0x36a6c8, points: [[1.58, -0.64], [2.45, 0.08], [4.1, -0.28], [4.0, -0.72], [3.78, -1.48], [3.15, -2.22], [2.22, -2.06], [1.54, -2.52], [0.82, -1.88], [1.58, -0.64]] },
      { color: 0xd2b16a, points: [[2.45, 0.08], [4.1, -0.28], [5.1, 0.18], [5.38, 0.24], [4.92, -0.58], [4.0, -0.72], [4.1, -0.28], [2.45, 0.08]] }
    ];
    regions.forEach((region, index) => {
      group.add(createMapRegion(THREE, region.points, region.color, -2.3 + index * 0.004));
      group.add(createMapLine(THREE, region.points, 0xb8f7ff, -2.17 + index * 0.004, 0.28));
    });

    const borderPoints = outline.map(([x, z]) => new THREE.Vector3(x, -2.22, z));
    const border = new THREE.Line(
      new THREE.BufferGeometry().setFromPoints(borderPoints),
      new THREE.LineBasicMaterial({
        color: 0x7de3ef,
        transparent: true,
        opacity: 0.94,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
    group.add(border);
    group.add(createMapTube(THREE, outline, 0x98fbff, -2.14, 0.026, 0.62));

    const internalLines = [
      [[-4.8, 1.46], [-3.2, 0.76], [-1.5, 0.92], [0.4, 0.28], [2.4, 0.38], [4.2, 0.05]],
      [[-3.6, -0.86], [-1.8, -0.45], [-0.4, -0.88], [1.3, -0.46], [3.1, -1.12]],
      [[-2.2, 2.26], [-1.72, 0.64], [-2.18, -0.9], [-1.36, -1.74]],
      [[0.58, 2.28], [0.84, 0.86], [1.22, -0.48], [0.8, -1.88]],
      [[2.62, 1.2], [2.86, 0.25], [2.46, -0.88], [3.18, -1.82]]
    ];
    internalLines.forEach((line, index) => {
      const points = line.map(([x, z]) => new THREE.Vector3(x, -2.12 + index * 0.012, z));
      group.add(new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(points),
        new THREE.LineBasicMaterial({
          color: index % 2 === 0 ? 0xf3d98a : 0x7de3ef,
          transparent: true,
          opacity: 0.34,
          depthWrite: false
        })
      ));
      group.add(createMapTube(THREE, line, index % 2 === 0 ? 0xf3d98a : 0x7de3ef, -2.1 + index * 0.014, 0.008, 0.26));
    });

    return group;
  }

  function createMapShape(THREE, points) {
    const shape = new THREE.Shape();
    points.forEach(([x, z], index) => {
      if (index === 0) shape.moveTo(x, z);
      else shape.lineTo(x, z);
    });
    return shape;
  }

  function createMapRegion(THREE, points, color, y) {
    const mesh = new THREE.Mesh(
      new THREE.ShapeGeometry(createMapShape(THREE, points)),
      new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity: 0.54,
        side: THREE.DoubleSide,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
    mesh.rotation.x = -Math.PI / 2;
    mesh.position.y = y;
    return mesh;
  }

  function createMapLine(THREE, points, color, y, opacity) {
    return new THREE.Line(
      new THREE.BufferGeometry().setFromPoints(points.map(([x, z]) => new THREE.Vector3(x, y, z))),
      new THREE.LineBasicMaterial({
        color,
        transparent: true,
        opacity,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
  }

  function createMapTube(THREE, points, color, y, radius, opacity) {
    const curve = new THREE.CatmullRomCurve3(points.map(([x, z]) => new THREE.Vector3(x, y, z)));
    const geometry = new THREE.TubeGeometry(curve, Math.max(48, points.length * 12), radius, 8, false);
    return new THREE.Mesh(
      geometry,
      new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
  }

  function createComputeNode(THREE, node, isCore) {
    const group = new THREE.Group();
    const color = Number.parseInt(node.color.replace('#', '0x'));
    const core = new THREE.Mesh(
      new THREE.IcosahedronGeometry(isCore ? 0.66 : 0.36, isCore ? 2 : 1),
      new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity: isCore ? 0.98 : 0.68,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
    group.add(core);

    const ring = new THREE.Mesh(
      new THREE.TorusGeometry(isCore ? 1.32 : 0.74, isCore ? 0.025 : 0.015, 16, 100),
      new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity: isCore ? 0.62 : 0.34,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
    ring.rotation.x = Math.PI / 2.35;
    group.add(ring);

    const label = new THREE.Sprite(
      new THREE.SpriteMaterial({
        map: createNodeLabelTexture(THREE, node.name, node.subtitle, color, isCore),
        transparent: true,
        opacity: isCore ? 0.94 : 0.62,
        depthWrite: false
      })
    );
    label.position.set(0, isCore ? -0.9 : -0.62, 0.18);
    label.scale.set(isCore ? 2.85 : 2.2, isCore ? 0.9 : 0.72, 1);
    group.add(label);

    return {
      group,
      pulse(elapsed, coreNode) {
        const pulse = 1 + Math.sin(elapsed * (coreNode ? 2.1 : 1.6)) * (coreNode ? 0.055 : 0.035);
        core.scale.setScalar(pulse);
        ring.rotation.z += coreNode ? 0.009 : 0.004;
        ring.material.opacity = (coreNode ? 0.58 : 0.28) + Math.sin(elapsed * 1.4) * 0.08;
      }
    };
  }

  function createGrowthTower(THREE, timeline) {
    const group = new THREE.Group();
    const bars = [];
    const heights = [1.15, 2.15, 3.45];
    timeline.forEach((item, index) => {
      const height = heights[index] || 1.2;
      const material = new THREE.MeshBasicMaterial({
        color: index === timeline.length - 1 ? 0xf3d98a : 0x7de3ef,
        transparent: true,
        opacity: 0.32,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      });
      const bar = new THREE.Mesh(new THREE.CylinderGeometry(0.19, 0.24, height, 32), material);
      bar.position.set(-0.72 + index * 0.72, -1.72 + height / 2, -0.55);
      group.add(bar);
      bars.push(bar);

      const label = new THREE.Sprite(
        new THREE.SpriteMaterial({
          map: createTimelineTexture(THREE, item.month, item.value, index === timeline.length - 1 ? 0xf3d98a : 0x7de3ef),
          transparent: true,
          opacity: 0.84,
          depthWrite: false
        })
      );
      label.position.set(bar.position.x, -1.25 + height, -0.48);
      label.scale.set(1.2, 0.5, 1);
      group.add(label);
    });

    return {
      group,
      animate(elapsed) {
        bars.forEach((bar, index) => {
          bar.material.opacity = 0.26 + Math.sin(elapsed * 1.2 + index) * 0.08;
        });
      }
    };
  }

  function createComputeLegend(THREE) {
    const group = new THREE.Group();
    const face = new THREE.Mesh(
      new THREE.PlaneGeometry(3.7, 1.45),
      new THREE.MeshBasicMaterial({
        map: createLegendTexture(THREE),
        transparent: true,
        opacity: 0.82,
        depthWrite: false
      })
    );
    group.add(face);

    const edges = [
      { x: -1.94, y: 0.76, w: 0.55, h: 0.02 },
      { x: 1.42, y: -0.76, w: 0.55, h: 0.02 },
      { x: -1.94, y: -0.48, w: 0.02, h: 0.42 },
      { x: 1.94, y: 0.48, w: 0.02, h: 0.42 }
    ];
    edges.forEach((edge) => {
      const mesh = new THREE.Mesh(
        new THREE.PlaneGeometry(edge.w, edge.h),
        new THREE.MeshBasicMaterial({ color: 0x7de3ef, transparent: true, opacity: 0.7, depthWrite: false, blending: THREE.AdditiveBlending })
      );
      mesh.position.set(edge.x, edge.y, 0.04);
      group.add(mesh);
    });
    return group;
  }

  function createEnergyRings(THREE) {
    const group = new THREE.Group();
    [1.8, 2.55, 3.35].forEach((radius, index) => {
      const ring = new THREE.Mesh(
        new THREE.TorusGeometry(radius, 0.018, 16, 140),
        new THREE.MeshBasicMaterial({
          color: index === 1 ? 0xf3d98a : 0x7de3ef,
          transparent: true,
          opacity: 0.22,
          depthWrite: false,
          blending: THREE.AdditiveBlending
        })
      );
      ring.rotation.x = Math.PI / 2.6 + index * 0.2;
      ring.rotation.y = index * 0.38;
      group.add(ring);
    });
    return group;
  }

  function createFlowParticles(THREE, curves, count) {
    const particles = [];
    const geometry = new THREE.SphereGeometry(0.064, 12, 12);
    for (let index = 0; index < count; index += 1) {
      const flow = curves[index % curves.length];
      const mesh = new THREE.Mesh(
        geometry,
        new THREE.MeshBasicMaterial({
          color: Number.parseInt(flow.color.replace('#', '0x')),
          transparent: true,
          opacity: 0.86,
          depthWrite: false,
          blending: THREE.AdditiveBlending
        })
      );
      particles.push({
        mesh,
        curve: flow.curve,
        offset: index / count,
        speed: 0.04 + (index % 9) * 0.006,
        baseScale: 0.8 + (index % 6) * 0.08
      });
    }
    return particles;
  }

  function createNodeLabelTexture(THREE, name, subtitle, color, isCore) {
    const canvas = document.createElement('canvas');
    canvas.width = 520;
    canvas.height = 170;
    const ctx = canvas.getContext('2d');
    const accent = `#${color.toString(16).padStart(6, '0')}`;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = 'rgba(6, 16, 30, 0.72)';
    ctx.strokeStyle = isCore ? 'rgba(243, 217, 138, 0.72)' : 'rgba(125, 227, 239, 0.38)';
    ctx.lineWidth = 3;
    roundRect(ctx, 10, 12, 500, 146, 18);
    ctx.fill();
    ctx.stroke();
    ctx.fillStyle = accent;
    ctx.font = '900 28px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(isCore ? '核心枢纽' : '数据中心集群', 34, 55);
    ctx.fillStyle = '#ffffff';
    ctx.font = isCore ? '950 48px "PingFang SC", "Microsoft YaHei", sans-serif' : '900 40px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(name, 34, 110);
    ctx.fillStyle = 'rgba(255, 255, 255, 0.62)';
    ctx.font = '750 22px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(subtitle, 34, 140);
    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    return texture;
  }

  function createTimelineTexture(THREE, month, value, color) {
    const canvas = document.createElement('canvas');
    canvas.width = 360;
    canvas.height = 150;
    const ctx = canvas.getContext('2d');
    const accent = `#${color.toString(16).padStart(6, '0')}`;
    ctx.fillStyle = 'rgba(6, 16, 30, 0.66)';
    ctx.strokeStyle = 'rgba(125, 227, 239, 0.34)';
    ctx.lineWidth = 2;
    roundRect(ctx, 8, 10, 344, 130, 18);
    ctx.fill();
    ctx.stroke();
    ctx.fillStyle = accent;
    ctx.font = '900 25px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(month, 28, 50);
    ctx.fillStyle = '#ffffff';
    ctx.font = '950 42px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(value, 28, 102);
    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    return texture;
  }

  function createLegendTexture(THREE) {
    const canvas = document.createElement('canvas');
    canvas.width = 900;
    canvas.height = 360;
    const ctx = canvas.getContext('2d');
    const gradient = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
    gradient.addColorStop(0, 'rgba(9, 26, 42, 0.9)');
    gradient.addColorStop(0.58, 'rgba(10, 52, 66, 0.62)');
    gradient.addColorStop(1, 'rgba(4, 12, 24, 0.85)');
    ctx.fillStyle = gradient;
    roundRect(ctx, 20, 20, 860, 320, 28);
    ctx.fill();
    ctx.strokeStyle = 'rgba(125, 227, 239, 0.58)';
    ctx.lineWidth = 3;
    ctx.stroke();

    ctx.fillStyle = '#7de3ef';
    ctx.font = '900 30px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText('全国一体化算力网络', 58, 82);
    ctx.fillStyle = '#ffffff';
    ctx.font = '950 54px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText('十个数据中心集群', 58, 158);
    ctx.fillStyle = 'rgba(255, 255, 255, 0.54)';
    ctx.font = '850 33px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText('东部需求穿梭至西部绿色算力', 58, 214);

    ctx.fillStyle = '#f3d98a';
    ctx.font = '950 42px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText('庆阳 14.2万P', 58, 292);
    ctx.fillStyle = 'rgba(255, 255, 255, 0.58)';
    ctx.font = '850 25px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText('算力规模持续跃升', 365, 292);

    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    return texture;
  }

  function createQingyangStars(THREE) {
    const geometry = new THREE.BufferGeometry();
    const positions = [];
    for (let index = 0; index < 420; index += 1) {
      positions.push((Math.random() - 0.5) * 34, Math.random() * 18 - 2.2, (Math.random() - 0.5) * 24);
    }
    geometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
    return new THREE.Points(
      geometry,
      new THREE.PointsMaterial({
        color: 0x7de3ef,
        size: 0.04,
        transparent: true,
        opacity: 0.5
      })
    );
  }

  function roundRect(ctx, x, y, width, height, radius) {
    ctx.beginPath();
    ctx.moveTo(x + radius, y);
    ctx.arcTo(x + width, y, x + width, y + height, radius);
    ctx.arcTo(x + width, y + height, x, y + height, radius);
    ctx.arcTo(x, y + height, x, y, radius);
    ctx.arcTo(x, y, x + width, y, radius);
    ctx.closePath();
  }
</script>
