    canvas.height = 240;
    const ctx = canvas.getContext('2d');
    const accent = `#${color.toString(16).padStart(6, '0')}`;
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    const panelGradient = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
    panelGradient.addColorStop(0, 'rgba(38, 88, 104, 0.92)');
    panelGradient.addColorStop(0.52, 'rgba(20, 58, 77, 0.88)');
    panelGradient.addColorStop(1, 'rgba(10, 30, 46, 0.9)');
    ctx.fillStyle = panelGradient;
    ctx.strokeStyle = 'rgba(213, 250, 255, 0.72)';
    ctx.lineWidth = 3;
    roundRect(ctx, 14, 14, 740, 212, 24);
    ctx.fill();
    ctx.stroke();

    ctx.fillStyle = 'rgba(255, 255, 255, 0.08)';
    roundRect(ctx, 32, 34, 704, 172, 18);
    ctx.fill();

    ctx.fillStyle = accent;
    roundRect(ctx, 46, 168, 676, 8, 4);
    ctx.fill();

    ctx.fillStyle = 'rgba(255, 255, 255, 0.13)';
    roundRect(ctx, 48, 58, 154, 74, 16);
    ctx.fill();
    ctx.fillStyle = accent;
    ctx.font = '900 38px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(number, 74, 106);
    ctx.fillStyle = '#ffffff';
    ctx.font = '950 58px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(title, 226, 112);
    ctx.fillStyle = 'rgba(255, 255, 255, 0.48)';
    ctx.font = '800 22px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText('QYVC AI Society', 226, 148);

    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    return texture;
  }

  function createBaseLabelTexture(THREE, title, subtitle) {
    const canvas = document.createElement('canvas');
