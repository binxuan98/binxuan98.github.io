<div class="compute-scene" data-compute-scene aria-hidden="true">
  <canvas data-compute-canvas></canvas>
  <div class="compute-scene__overlay"></div>
</div>

<script>
  const roots = document.querySelectorAll('[data-compute-scene]');

  if (roots.length > 0) {
    import('three').then((THREE) => {
      roots.forEach((root) => initScene(THREE, root));
    });
  }

  function initScene(THREE, root) {
    const canvas = root.querySelector('[data-compute-canvas]');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
      preserveDrawingBuffer: true,
      powerPreference: 'high-performance'
    });

    renderer.setClearColor(0x000000, 0);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.75));

    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x06101e, 0.035);

    const camera = new THREE.PerspectiveCamera(42, 1, 0.1, 120);
    camera.position.set(0, 8.4, 23);
    camera.lookAt(0, 0.4, 0);

    const group = new THREE.Group();
    scene.add(group);

    const nodePositions = [
      [-8.6, 1.4, -5.4], [-6.2, -0.4, 0.4], [-3.8, 2.2, -2.4], [-1.2, 0.2, 2.8],
      [1.5, 2.7, -4.2], [3.8, -0.3, 0.6], [6.2, 1.7, -2.1], [8.2, -0.1, 3.2],
      [-7.5, 3.6, 3.4], [0.2, 4.2, 0.2], [6.9, 4.1, 1.9], [-0.8, -1.4, -5.6]
    ].map(([x, y, z]) => new THREE.Vector3(x, y, z));

    const nodeGeometry = new THREE.IcosahedronGeometry(0.22, 1);
    const nodeMaterial = new THREE.MeshBasicMaterial({ color: 0x7de3ef });
    const hubMaterial = new THREE.MeshBasicMaterial({ color: 0xf3d98a });

    nodePositions.forEach((position, index) => {
      const mesh = new THREE.Mesh(nodeGeometry, index === 9 ? hubMaterial : nodeMaterial);
      mesh.position.copy(position);
      mesh.scale.setScalar(index === 9 ? 1.65 : 1);
      group.add(mesh);

      const halo = new THREE.Mesh(
        new THREE.RingGeometry(0.36, 0.39, 32),
        new THREE.MeshBasicMaterial({
          color: index === 9 ? 0xf3d98a : 0x7de3ef,
          transparent: true,
          opacity: index === 9 ? 0.5 : 0.25,
          side: THREE.DoubleSide
        })
      );
      halo.position.copy(position);
      halo.lookAt(camera.position);
      group.add(halo);
    });

    const links = [
      [0, 1], [0, 8], [1, 2], [1, 11], [2, 3], [2, 9], [3, 5], [3, 9],
      [4, 6], [4, 9], [5, 6], [5, 7], [6, 10], [7, 10], [8, 9], [9, 10], [11, 3]
    ];

    const lineMaterial = new THREE.LineBasicMaterial({
      color: 0x42d9e8,
      transparent: true,
      opacity: 0.28
    });

    links.forEach(([start, end]) => {
      const geometry = new THREE.BufferGeometry().setFromPoints([nodePositions[start], nodePositions[end]]);
      group.add(new THREE.Line(geometry, lineMaterial));
    });

    const pulseGeometry = new THREE.SphereGeometry(0.075, 16, 16);
    const pulseMaterial = new THREE.MeshBasicMaterial({ color: 0xf3d98a });
    const pulses = links.map(([start, end], index) => {
      const mesh = new THREE.Mesh(pulseGeometry, pulseMaterial);
      mesh.userData = {
        start: nodePositions[start],
        end: nodePositions[end],
        offset: index / links.length,
        speed: 0.09 + (index % 5) * 0.015
      };
      group.add(mesh);
      return mesh;
    });

    const terrainGroup = new THREE.Group();
    terrainGroup.position.y = -3.25;
    group.add(terrainGroup);

    const terrainMaterial = new THREE.LineBasicMaterial({
      color: 0xd7a43a,
      transparent: true,
      opacity: 0.34
    });
    const terrainCyanMaterial = new THREE.LineBasicMaterial({
      color: 0x55dbea,
      transparent: true,
      opacity: 0.26
    });

    for (let row = 0; row < 9; row += 1) {
      const points = [];
      const z = -8 + row * 2;
      for (let i = 0; i < 90; i += 1) {
        const x = -12 + i * 0.28;
        const y = Math.sin(i * 0.22 + row * 0.9) * 0.18 + Math.cos(i * 0.07 + row) * 0.22;
        points.push(new THREE.Vector3(x, y, z + Math.sin(i * 0.08) * 0.22));
      }
      const geometry = new THREE.BufferGeometry().setFromPoints(points);
      const line = new THREE.Line(geometry, row % 3 === 0 ? terrainCyanMaterial : terrainMaterial);
      terrainGroup.add(line);
    }

    const grid = new THREE.GridHelper(28, 28, 0x42d9e8, 0x42d9e8);
    grid.position.y = -3.48;
    grid.material.transparent = true;
    grid.material.opacity = 0.12;
    group.add(grid);

    const starGeometry = new THREE.BufferGeometry();
    const starPositions = [];
    for (let i = 0; i < 260; i += 1) {
      starPositions.push(
        (Math.random() - 0.5) * 36,
        Math.random() * 18 - 2,
        (Math.random() - 0.5) * 26
      );
    }
    starGeometry.setAttribute('position', new THREE.Float32BufferAttribute(starPositions, 3));
    const starMaterial = new THREE.PointsMaterial({
      color: 0x7de3ef,
      size: 0.035,
      transparent: true,
      opacity: 0.55
    });
    const stars = new THREE.Points(starGeometry, starMaterial);
    group.add(stars);

    let frameId = 0;
    const clock = new THREE.Clock();

    function resize() {
      const rect = root.getBoundingClientRect();
      const width = Math.max(1, Math.floor(rect.width));
      const height = Math.max(1, Math.floor(rect.height));
      renderer.setSize(width, height, false);
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
    }

    function render() {
      const elapsed = clock.getElapsedTime();
      group.rotation.y = Math.sin(elapsed * 0.14) * 0.11;
      group.rotation.x = Math.sin(elapsed * 0.08) * 0.025;
      terrainGroup.position.x = Math.sin(elapsed * 0.2) * 0.28;
      stars.rotation.y = elapsed * 0.025;

      pulses.forEach((pulse) => {
        const t = (elapsed * pulse.userData.speed + pulse.userData.offset) % 1;
        pulse.position.lerpVectors(pulse.userData.start, pulse.userData.end, t);
        pulse.scale.setScalar(0.85 + Math.sin((t + elapsed) * Math.PI * 2) * 0.28);
      });

      renderer.render(scene, camera);
      if (!prefersReducedMotion.matches) frameId = window.requestAnimationFrame(render);
    }

    const observer = new ResizeObserver(resize);
    observer.observe(root);
    resize();

    if (prefersReducedMotion.matches) {
      renderer.render(scene, camera);
    } else {
      frameId = window.requestAnimationFrame(render);
    }

    prefersReducedMotion.addEventListener?.('change', () => {
      window.cancelAnimationFrame(frameId);
      clock.start();
      resize();
      render();
    });

    window.addEventListener('pagehide', () => {
      observer.disconnect();
      window.cancelAnimationFrame(frameId);
      renderer.dispose();
      nodeGeometry.dispose();
      pulseGeometry.dispose();
      starGeometry.dispose();
    }, { once: true });
  }
</script>
