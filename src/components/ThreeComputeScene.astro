---
import portrait from '../assets/images/zhang-binxuan-academic-id.png';
import { societyModules } from '../data/society';
import { profile } from '../data/profile';

const sceneModules = societyModules.map(({ number, icon, shortTitle, title, text, tags, summary }) => ({
  number,
  icon,
  shortTitle,
  title,
  text,
  tags,
  summary
}));
---

<div
  class="compute-scene"
  data-compute-scene
  data-compute-modules={JSON.stringify(sceneModules)}
  data-presenter-name={profile.name}
  data-presenter-role={profile.role}
  data-portrait-src={portrait.src}
  aria-hidden="true"
>
  <canvas data-compute-canvas></canvas>
  <div class="compute-scene__overlay"></div>
</div>

<script>
  const roots = document.querySelectorAll('[data-compute-scene]');

  if (roots.length > 0) {
    import('three').then((THREE) => {
      roots.forEach((root) => initScene(THREE, root));
    });
  }

  function initScene(THREE, root) {
    const canvas = root.querySelector('[data-compute-canvas]');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const modules = JSON.parse(root.dataset.computeModules || '[]');
    const presenter = {
      name: root.dataset.presenterName || '张斌轩',
      role: root.dataset.presenterRole || '智研社创始人 · 指导老师',
      portraitSrc: root.dataset.portraitSrc || ''
    };
    let portraitImage = null;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
      preserveDrawingBuffer: true,
      powerPreference: 'high-performance'
    });

    renderer.setClearColor(0x000000, 0);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.7));
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.05;

    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x06101e, 0.026);
    scene.add(new THREE.HemisphereLight(0xd8fbff, 0x0b2434, 1.08));

    const keyLight = new THREE.DirectionalLight(0xffffff, 2.75);
    keyLight.position.set(-4.8, 8.2, 9.4);
    scene.add(keyLight);

    const rimLight = new THREE.DirectionalLight(0x7de3ef, 1.45);
    rimLight.position.set(6.2, 4.6, -4.8);
    scene.add(rimLight);

    const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 140);
    camera.position.set(0, 8.4, 19.2);

    const stage = new THREE.Group();
    const moduleLayer = new THREE.Group();
    const terrainLayer = new THREE.Group();
    const flowLayer = new THREE.Group();
    scene.add(stage);
    stage.add(terrainLayer, moduleLayer, flowLayer);
    stage.position.set(0, 0.18, 1.45);
    stage.scale.setScalar(1.12);

    const palette = [0x7de3ef, 0xf3d98a, 0x74f0a7, 0xaec7ff, 0xffb37a];
    const moduleThemes = [
      { body: 0x5f9eac, panel: 0x173e52, accent: 0x7de3ef, warm: 0xf3d98a },
      { body: 0x78a86d, panel: 0x223f35, accent: 0x74f0a7, warm: 0xf3d98a },
      { body: 0x7c83bd, panel: 0x283357, accent: 0xaec7ff, warm: 0xf3d98a },
      { body: 0xbe8756, panel: 0x493522, accent: 0xffb37a, warm: 0x7de3ef },
      { body: 0x4a9b85, panel: 0x173f38, accent: 0x74f0a7, warm: 0x7de3ef }
    ];
    const moduleObjects = [];
    const radialLinks = [];
    const orbitRadius = 5.05;
    const orbitAngles = [-Math.PI * 0.58, -Math.PI * 0.2, Math.PI * 0.18, Math.PI * 0.55, Math.PI * 0.93];

    const hub = createHub(THREE);
    hub.position.set(0, 0.38, 0);
    moduleLayer.add(hub);

    modules.forEach((module, index) => {
      const angle = orbitAngles[index] ?? (index / Math.max(1, modules.length)) * Math.PI * 2;
      const position = new THREE.Vector3(
        Math.cos(angle) * orbitRadius,
        0.58 + Math.sin(index * 1.7) * 0.18,
        Math.sin(angle) * orbitRadius * 0.72
      );
      const theme = moduleThemes[index % moduleThemes.length];
      const moduleObject = createModulePod(THREE, module, index, palette[index % palette.length], theme);
      moduleObject.group.position.copy(position);
      moduleObject.group.lookAt(hub.position);
      moduleLayer.add(moduleObject.group);
      moduleObjects.push({ ...moduleObject, position, angle });

      const curve = new THREE.CatmullRomCurve3([
        hub.position.clone(),
        new THREE.Vector3(position.x * 0.48, position.y + 0.92, position.z * 0.5),
        position.clone()
      ]);
      const line = new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(curve.getPoints(80)),
        new THREE.LineBasicMaterial({
          color: palette[index % palette.length],
          transparent: true,
          opacity: 0.18,
          depthWrite: false,
          blending: THREE.AdditiveBlending
        })
      );
      radialLinks.push({ curve, line, moduleIndex: index });
      flowLayer.add(line);
    });

    createTerrain(THREE, terrainLayer);

    const detailCard = createDetailCard(THREE, modules[0], palette[0], 0, modules.length, presenter, portraitImage);
    detailCard.group.position.set(5.22, 2.08, 5.95);
    detailCard.group.rotation.set(-0.018, -0.14, 0.005);
    scene.add(detailCard.group);

    const signalField = createSignalField(THREE);
    stage.add(signalField);

    let activeIndex = 0;
    let targetRotation = 0.2;
    let activeStartedAt = 0;
    let frameId = 0;
    let startedAt = performance.now();
    const lookTarget = new THREE.Vector3(0, 0.5, 0);
    const moduleDuration = 6;

    if (presenter.portraitSrc) {
      const image = new Image();
      image.decoding = 'async';
      image.onload = () => {
        portraitImage = image;
        detailCard.update(modules[activeIndex], palette[activeIndex % palette.length], activeIndex, modules.length, presenter, portraitImage);
      };
      image.src = presenter.portraitSrc;
    }

    function setActive(index) {
      activeIndex = (index + moduleObjects.length) % moduleObjects.length;
      const active = moduleObjects[activeIndex];
      targetRotation = Math.atan2(-active.position.x, active.position.z);
      activeStartedAt = getElapsedTime();
      root.dataset.activeModule = String(activeIndex);
      detailCard.update(modules[activeIndex], palette[activeIndex % palette.length], activeIndex, modules.length, presenter, portraitImage);
      if (prefersReducedMotion.matches) {
        stage.rotation.y = targetRotation;
        resize();
        render();
      }
    }

    function handleModuleChange(event) {
      if (!event.detail || typeof event.detail.index !== 'number') return;
      setActive(event.detail.index);
    }

    window.addEventListener('society:module-change', handleModuleChange);
    setActive(0);

    function resize() {
      const rect = root.getBoundingClientRect();
      const width = Math.max(1, Math.floor(rect.width));
      const height = Math.max(1, Math.floor(rect.height));
      renderer.setSize(width, height, false);
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
    }

    function render() {
      const elapsed = getElapsedTime();
      stage.rotation.y += (targetRotation - stage.rotation.y) * 0.13;
      stage.rotation.x = Math.sin(elapsed * 0.16) * 0.025;
      terrainLayer.position.x = Math.sin(elapsed * 0.22) * 0.3;
      signalField.rotation.y = Math.sin(elapsed * 0.12) * 0.08;

      lookTarget.set(0, 0.92, 1.18);
      camera.position.x += (0 - camera.position.x) * 0.018;
      camera.lookAt(lookTarget);

      moduleObjects.forEach((moduleObject, index) => {
        const isActive = index === activeIndex;
        const pulse = 1 + Math.sin(elapsed * 2.2 + index) * 0.04;
        const baseScale = isActive ? 1.14 : 0.82;
        moduleObject.group.scale.setScalar(baseScale * pulse);
        moduleObject.glow.material.opacity = isActive ? 0.28 : 0.035;
        moduleObject.beacon.material.opacity = isActive ? 0.46 : 0.055;
        moduleObject.label.material.opacity = isActive ? 0.96 : 0.24;
        moduleObject.panel.material.opacity = isActive ? 0.58 : 0.14;
        moduleObject.light.intensity = isActive ? 1.12 : 0.24;
        moduleObject.visual.rotation.y += isActive ? 0.0042 : 0.0014;
        moduleObject.materials.forEach((entry) => {
          entry.material.opacity = isActive ? entry.activeOpacity : entry.idleOpacity;
        });
      });

      radialLinks.forEach((link) => {
        link.line.material.opacity = link.moduleIndex === activeIndex ? 0.5 : 0.045;
      });

      hub.rotation.y -= 0.0012;
      hub.rotation.z = Math.sin(elapsed * 0.45) * 0.018;

      const progress = prefersReducedMotion.matches
        ? 1
        : Math.min(1, Math.max(0, (elapsed - activeStartedAt) / moduleDuration));
      detailCard.group.position.y = 2.05 + Math.sin(elapsed * 0.7) * 0.055;
      detailCard.group.rotation.y = -0.14 + Math.sin(elapsed * 0.24) * 0.008;
      detailCard.group.rotation.x = -0.02 + Math.sin(elapsed * 0.18) * 0.008;
      detailCard.updateProgress(progress);

      renderer.render(scene, camera);
      if (!prefersReducedMotion.matches) frameId = window.requestAnimationFrame(render);
    }

    const observer = new ResizeObserver(resize);
    observer.observe(root);
    resize();

    if (prefersReducedMotion.matches) {
      renderer.render(scene, camera);
    } else {
      frameId = window.requestAnimationFrame(render);
    }

    prefersReducedMotion.addEventListener?.('change', () => {
      window.cancelAnimationFrame(frameId);
      startedAt = performance.now();
      activeStartedAt = 0;
      resize();
      render();
    });

    window.addEventListener('pagehide', () => {
      observer.disconnect();
      window.removeEventListener('society:module-change', handleModuleChange);
      window.cancelAnimationFrame(frameId);
      renderer.dispose();
      scene.traverse((object) => {
        if (object.geometry) object.geometry.dispose();
        if (object.material) {
          const materials = Array.isArray(object.material) ? object.material : [object.material];
          materials.forEach((material) => {
            if (material.map) material.map.dispose();
            material.dispose();
          });
        }
      });
    }, { once: true });

    function getElapsedTime() {
      return (performance.now() - startedAt) / 1000;
    }
  }

  function createHub(THREE) {
    const group = new THREE.Group();
    const addBox = (width, height, depth, material, x, y, z, rotationY = 0) => {
      const mesh = new THREE.Mesh(new THREE.BoxGeometry(width, height, depth), material);
      mesh.position.set(x, y, z);
      mesh.rotation.y = rotationY;
      group.add(mesh);
      return mesh;
    };

    const glassMaterial = new THREE.MeshBasicMaterial({
      color: 0xc5fbff,
      transparent: true,
      opacity: 0.62,
      depthWrite: false,
      blending: THREE.AdditiveBlending
    });
    const goldMaterial = new THREE.MeshBasicMaterial({
      color: 0xf3d98a,
      transparent: true,
      opacity: 0.48,
      depthWrite: false,
      blending: THREE.AdditiveBlending
    });

    const platform = new THREE.Mesh(
      new THREE.BoxGeometry(5.2, 0.18, 3.55),
      new THREE.MeshPhysicalMaterial({
        color: 0x3d7180,
        emissive: 0x12384a,
        emissiveIntensity: 0.18,
        metalness: 0.34,
        roughness: 0.29,
        clearcoat: 0.8,
        clearcoatRoughness: 0.18,
        transparent: true,
        opacity: 0.94
      })
    );
    platform.position.y = -0.64;
    group.add(platform);

    const platformEdge = new THREE.Mesh(
      new THREE.BoxGeometry(5.42, 0.035, 3.78),
      new THREE.MeshBasicMaterial({
        color: 0xa7f4ff,
        transparent: true,
        opacity: 0.34,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
    platformEdge.position.y = -0.53;
    group.add(platformEdge);

    const upperDeck = addBox(
      4.66,
      0.045,
      2.86,
      new THREE.MeshPhysicalMaterial({
        color: 0x8fb4bb,
        emissive: 0x153b4a,
        emissiveIntensity: 0.12,
        metalness: 0.22,
        roughness: 0.2,
        clearcoat: 1,
        clearcoatRoughness: 0.12,
        transparent: true,
        opacity: 0.28
      }),
      0,
      -0.505,
      0
    );
    upperDeck.renderOrder = 2;

    [
      { width: 4.04, depth: 0.035, x: -0.15, z: 1.16, material: goldMaterial, rotation: 0.04 },
      { width: 3.25, depth: 0.028, x: 0.42, z: -1.18, material: glassMaterial, rotation: -0.04 },
      { width: 0.035, depth: 2.38, x: -2.05, z: 0, material: glassMaterial, rotation: 0 },
      { width: 0.035, depth: 1.98, x: 2.16, z: 0.16, material: goldMaterial, rotation: 0 }
    ].forEach((channel) => {
      addBox(channel.width, 0.018, channel.depth, channel.material.clone(), channel.x, -0.465, channel.z, channel.rotation);
    });

    const buildingMaterials = [
      new THREE.MeshPhysicalMaterial({
        color: 0x5d91a1,
        emissive: 0x17485a,
        emissiveIntensity: 0.3,
        metalness: 0.36,
        roughness: 0.22,
        clearcoat: 1,
        clearcoatRoughness: 0.12,
        transparent: true,
        opacity: 0.96
      }),
      new THREE.MeshPhysicalMaterial({
        color: 0x7c8d94,
        emissive: 0x273d43,
        emissiveIntensity: 0.22,
        metalness: 0.42,
        roughness: 0.26,
        clearcoat: 0.9,
        clearcoatRoughness: 0.14,
        transparent: true,
        opacity: 0.94
      }),
      new THREE.MeshPhysicalMaterial({
        color: 0x8d826d,
        emissive: 0x42351f,
        emissiveIntensity: 0.18,
        metalness: 0.38,
        roughness: 0.28,
        clearcoat: 0.78,
        clearcoatRoughness: 0.16,
        transparent: true,
        opacity: 0.94
      })
    ];

    const coreMaterial = new THREE.MeshPhysicalMaterial({
      color: 0x9eb7bd,
      emissive: 0x1b4854,
      emissiveIntensity: 0.32,
      metalness: 0.34,
      roughness: 0.18,
      clearcoat: 1,
      clearcoatRoughness: 0.1,
      transparent: true,
      opacity: 0.92
    });

    const buildings = [
      { x: -1.48, z: -0.68, w: 0.62, h: 1.08, d: 1.18, material: 0 },
      { x: -0.62, z: -0.64, w: 0.56, h: 0.86, d: 1.05, material: 1 },
      { x: 0.34, z: -0.62, w: 0.72, h: 1.22, d: 1.22, material: 0 },
      { x: 1.36, z: -0.58, w: 0.58, h: 0.98, d: 1.08, material: 2 }
    ];

    buildings.forEach((item, buildingIndex) => {
      const building = new THREE.Mesh(
        new THREE.BoxGeometry(item.w, item.h, item.d),
        buildingMaterials[item.material].clone()
      );
      building.position.set(item.x, -0.44 + item.h / 2, item.z);
      building.rotation.y = 0.08;
      group.add(building);

      const roof = new THREE.Mesh(
        new THREE.BoxGeometry(item.w * 0.72, 0.024, item.d * 0.18),
        buildingIndex % 2 === 0 ? glassMaterial.clone() : goldMaterial.clone()
      );
      roof.position.set(item.x, -0.42 + item.h + 0.02, item.z + item.d * 0.16);
      roof.rotation.y = 0.08;
      roof.material.opacity = buildingIndex % 2 === 0 ? 0.48 : 0.34;
      group.add(roof);

      for (let floor = 0; floor < 4; floor += 1) {
        const strip = new THREE.Mesh(
          new THREE.BoxGeometry(item.w * 0.74, 0.018, 0.016),
          glassMaterial.clone()
        );
        strip.position.set(item.x, -0.72 + floor * item.h * 0.22 + item.h * 0.25, item.z + item.d / 2 + 0.012);
        strip.rotation.y = 0.08;
        strip.material.opacity = 0.48 + buildingIndex * 0.045;
        group.add(strip);
      }
    });

    const commandCore = new THREE.Mesh(
      new THREE.CylinderGeometry(0.2, 0.34, 1.24, 8),
      coreMaterial
    );
    commandCore.position.set(1.72, 0.11, 0.72);
    commandCore.rotation.y = Math.PI / 8;
    group.add(commandCore);

    for (let strip = 0; strip < 4; strip += 1) {
      const angle = strip * Math.PI * 0.5 + Math.PI * 0.25;
      const lightStrip = new THREE.Mesh(
        new THREE.BoxGeometry(0.028, 0.92, 0.016),
        strip % 2 === 0 ? glassMaterial.clone() : goldMaterial.clone()
      );
      lightStrip.position.set(
        commandCore.position.x + Math.cos(angle) * 0.23,
        0.2,
        commandCore.position.z + Math.sin(angle) * 0.23
      );
      lightStrip.rotation.y = -angle;
      lightStrip.material.opacity = strip % 2 === 0 ? 0.58 : 0.38;
      group.add(lightStrip);
    }

    const rackMaterial = new THREE.MeshPhysicalMaterial({
      color: 0x315c66,
      emissive: 0x0e3440,
      emissiveIntensity: 0.26,
      metalness: 0.38,
      roughness: 0.3,
      clearcoat: 0.8,
      transparent: true,
      opacity: 0.95
    });

    for (let row = 0; row < 3; row += 1) {
      for (let rack = 0; rack < 6; rack += 1) {
        const unit = new THREE.Mesh(
          new THREE.BoxGeometry(0.14, 0.38, 0.42),
          rackMaterial.clone()
        );
        unit.position.set(-1.72 + rack * 0.25, -0.27, 0.64 + row * 0.34);
        unit.rotation.y = -0.12;
        group.add(unit);

        const led = new THREE.Mesh(
          new THREE.BoxGeometry(0.08, 0.012, 0.012),
          glassMaterial.clone()
        );
        led.position.set(unit.position.x, unit.position.y + 0.1, unit.position.z + 0.216);
        led.rotation.y = -0.12;
        led.material.opacity = 0.58;
        group.add(led);
      }
    }

    const towerBeacon = new THREE.Mesh(
      new THREE.CylinderGeometry(0.012, 0.012, 1.88, 24),
      new THREE.MeshBasicMaterial({
        color: 0xf3d98a,
        transparent: true,
        opacity: 0.5,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
    towerBeacon.position.set(1.72, 1.02, 0.72);
    group.add(towerBeacon);

    const cornerBeams = [
      [-2.42, -1.68],
      [2.42, -1.68],
      [-2.42, 1.68],
      [2.42, 1.68]
    ];
    cornerBeams.forEach(([x, z]) => {
      const beam = new THREE.Mesh(
        new THREE.CylinderGeometry(0.012, 0.018, 1.25, 18),
        new THREE.MeshBasicMaterial({
          color: 0x7de3ef,
          transparent: true,
          opacity: 0.24,
          depthWrite: false,
          blending: THREE.AdditiveBlending
        })
      );
      beam.position.set(x, 0.06, z);
      group.add(beam);
    });

    const coolingUnits = [
      [-2.05, 0.04],
      [-1.73, 0.04],
      [2.03, -0.1],
      [2.34, -0.1]
    ];
    coolingUnits.forEach(([x, z]) => {
      const unit = new THREE.Mesh(
        new THREE.CylinderGeometry(0.13, 0.13, 0.22, 32),
        new THREE.MeshStandardMaterial({
          color: 0xd2edf0,
          metalness: 0.48,
          roughness: 0.36,
          transparent: true,
          opacity: 0.78
        })
      );
      unit.position.set(x, -0.41, z);
      group.add(unit);

      const cap = new THREE.Mesh(
        new THREE.CylinderGeometry(0.09, 0.09, 0.01, 32),
        glassMaterial.clone()
      );
      cap.position.set(x, -0.29, z);
      cap.material.opacity = 0.22;
      group.add(cap);
    });

    const label = new THREE.Sprite(
      new THREE.SpriteMaterial({
        map: createBaseLabelTexture(THREE, '庆阳算力基地', '智研社人才培养沙盘'),
        transparent: true,
        opacity: 0.92,
        depthWrite: false
      })
    );
    label.position.set(0, 1.34, -1.62);
    label.scale.set(2.76, 0.72, 1);
    group.add(label);

    const glow = new THREE.Sprite(
      new THREE.SpriteMaterial({
        map: createGlowTexture(THREE, 0xf3d98a),
        transparent: true,
        opacity: 0.22,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
    glow.scale.set(4.8, 3.2, 1);
    glow.position.y = -0.46;
    group.add(glow);

    const light = new THREE.PointLight(0xf3d98a, 0.82, 7.5);
    light.position.set(0, 0.25, 0.1);
    group.add(light);

    return group;
  }

  function createModulePod(THREE, module, index, color, theme = {}) {
    const group = new THREE.Group();
    const materials = [];
    const bodyColor = theme.body ?? 0x5d8795;
    const panelColor = theme.panel ?? 0x123348;
    const accentColor = theme.accent ?? color;
    const warmColor = theme.warm ?? 0xf3d98a;
    const track = (material, activeOpacity, idleOpacity) => {
      material.transparent = true;
      material.opacity = idleOpacity;
      materials.push({ material, activeOpacity, idleOpacity });
      return material;
    };

    const physical = (options, activeOpacity = 0.96, idleOpacity = 0.68) => track(
      new THREE.MeshPhysicalMaterial(options),
      activeOpacity,
      idleOpacity
    );
    const basic = (options, activeOpacity = 0.9, idleOpacity = 0.34) => track(
      new THREE.MeshBasicMaterial(options),
      activeOpacity,
      idleOpacity
    );
    const accentMaterial = (activeOpacity = 0.92, idleOpacity = 0.36) => basic(
      {
        color: accentColor,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      },
      activeOpacity,
      idleOpacity
    );
    const warmMaterial = (activeOpacity = 0.82, idleOpacity = 0.26) => basic(
      {
        color: warmColor,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      },
      activeOpacity,
      idleOpacity
    );
    const structureMaterial = (activeOpacity = 0.98, idleOpacity = 0.72) => physical(
      {
        color: bodyColor,
        emissive: panelColor,
        emissiveIntensity: 0.22,
        metalness: 0.42,
        roughness: 0.24,
        clearcoat: 1,
        clearcoatRoughness: 0.14
      },
      activeOpacity,
      idleOpacity
    );
    const glassMaterial = (activeOpacity = 0.7, idleOpacity = 0.22) => basic(
      {
        color: 0xd8fbff,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      },
      activeOpacity,
      idleOpacity
    );

    const platform = new THREE.Mesh(
      new THREE.CylinderGeometry(0.62, 0.76, 0.12, 12),
      physical(
        {
          color: panelColor,
          emissive: panelColor,
          emissiveIntensity: 0.2,
          metalness: 0.36,
          roughness: 0.28,
          clearcoat: 0.86,
          clearcoatRoughness: 0.16
        },
        0.96,
        0.72
      )
    );
    platform.position.y = -0.58;
    platform.rotation.y = Math.PI / 12;
    group.add(platform);

    const topPlate = new THREE.Mesh(
      new THREE.CylinderGeometry(0.55, 0.59, 0.035, 12),
      physical(
        {
          color: bodyColor,
          emissive: panelColor,
          emissiveIntensity: 0.12,
          metalness: 0.3,
          roughness: 0.2,
          clearcoat: 1,
          clearcoatRoughness: 0.1
        },
        0.9,
        0.46
      )
    );
    topPlate.position.y = -0.49;
    topPlate.rotation.y = Math.PI / 12;
    group.add(topPlate);

    const visual = new THREE.Group();
    visual.position.y = 0.16;
    group.add(visual);

    const addBox = (parent, width, height, depth, x, y, z, material, rotationY = 0, rotationZ = 0) => {
      const mesh = new THREE.Mesh(new THREE.BoxGeometry(width, height, depth), material);
      mesh.position.set(x, y, z);
      mesh.rotation.y = rotationY;
      mesh.rotation.z = rotationZ;
      parent.add(mesh);
      return mesh;
    };
    const addCylinder = (parent, radiusTop, radiusBottom, height, segments, x, y, z, material, rotation = {}) => {
      const mesh = new THREE.Mesh(new THREE.CylinderGeometry(radiusTop, radiusBottom, height, segments), material);
      mesh.position.set(x, y, z);
      mesh.rotation.x = rotation.x ?? 0;
      mesh.rotation.y = rotation.y ?? 0;
      mesh.rotation.z = rotation.z ?? 0;
      parent.add(mesh);
      return mesh;
    };

    if (index === 0) {
      addBox(visual, 0.78, 0.055, 0.42, 0, -0.16, 0, structureMaterial(0.95, 0.56), 0.04);
      addBox(visual, 0.1, 0.72, 0.14, -0.3, 0.08, 0, structureMaterial(), 0.04);
      addBox(visual, 0.1, 0.72, 0.14, 0.3, 0.08, 0, structureMaterial(), 0.04);
      addBox(visual, 0.72, 0.1, 0.16, 0, 0.48, 0, structureMaterial(), 0.04);
      addBox(visual, 0.44, 0.31, 0.028, 0, 0.14, 0.24, glassMaterial(0.78, 0.24), 0.04);
      addBox(visual, 0.34, 0.024, 0.035, -0.02, 0.32, 0.265, accentMaterial(0.95, 0.34), 0.04);
      addBox(visual, 0.58, 0.026, 0.026, 0, 0.56, 0.09, warmMaterial(0.76, 0.24), 0.04);
    } else if (index === 1) {
      addBox(visual, 0.88, 0.06, 0.34, 0, -0.17, 0, structureMaterial(0.94, 0.52), -0.02);
      for (let item = 0; item < 3; item += 1) {
        const x = -0.28 + item * 0.28;
        addCylinder(visual, 0.12, 0.14, 0.56, 28, x, 0.06, 0, structureMaterial(), { z: Math.PI / 2 });
        addBox(visual, 0.035, 0.23, 0.035, x, 0.07, 0.2, accentMaterial(0.9, 0.3));
        addBox(visual, 0.14, 0.018, 0.032, x, 0.24, 0.02, warmMaterial(0.7, 0.22));
      }
      addBox(visual, 0.66, 0.026, 0.026, 0, 0.42, 0.08, glassMaterial(0.72, 0.2));
    } else if (index === 2) {
      addBox(visual, 0.4, 0.82, 0.36, -0.08, 0.18, 0, structureMaterial(), 0.06);
      addBox(visual, 0.28, 0.44, 0.28, 0.28, -0.02, 0.02, structureMaterial(0.94, 0.58), 0.06);
      addCylinder(visual, 0.24, 0.32, 0.13, 4, -0.08, 0.66, 0, accentMaterial(0.9, 0.34), { y: Math.PI / 4 });
      addBox(visual, 0.018, 0.72, 0.018, 0.18, 0.38, 0.22, warmMaterial(0.72, 0.18));
      addBox(visual, 0.46, 0.026, 0.026, -0.08, 0.06, 0.21, glassMaterial(0.78, 0.22), 0.06);
      addBox(visual, 0.46, 0.026, 0.026, -0.08, 0.28, 0.21, glassMaterial(0.78, 0.22), 0.06);
    } else if (index === 3) {
      addBox(visual, 0.82, 0.06, 0.48, 0, -0.18, 0, structureMaterial(0.94, 0.52));
      for (let rack = 0; rack < 4; rack += 1) {
        addBox(visual, 0.52, 0.1, 0.34, -0.08, -0.02 + rack * 0.15, 0, structureMaterial(), -0.04);
        addBox(visual, 0.33, 0.015, 0.018, -0.08, 0.018 + rack * 0.15, 0.18, rack % 2 === 0 ? accentMaterial(0.96, 0.34) : warmMaterial(0.76, 0.22), -0.04);
      }
      addBox(visual, 0.18, 0.42, 0.1, 0.34, 0.14, -0.1, glassMaterial(0.72, 0.2), -0.08);
      addBox(visual, 0.22, 0.03, 0.42, 0.28, -0.06, 0.1, warmMaterial(0.72, 0.18), -0.08);
    } else {
      addBox(visual, 0.86, 0.06, 0.36, 0, -0.17, 0, structureMaterial(0.94, 0.52), 0.02);
      addCylinder(visual, 0.16, 0.26, 0.72, 8, 0, 0.18, 0, structureMaterial(), { y: Math.PI / 8 });
      addCylinder(visual, 0.08, 0.13, 0.18, 8, 0, 0.62, 0, accentMaterial(0.92, 0.3), { y: Math.PI / 8 });
      [-0.28, 0, 0.28].forEach((x, bladeIndex) => {
        addBox(visual, 0.07, 0.48 + bladeIndex * 0.08, 0.05, x, 0.08 + bladeIndex * 0.04, 0.22, bladeIndex === 1 ? warmMaterial(0.76, 0.22) : glassMaterial(0.68, 0.18), 0.08);
      });
      addBox(visual, 0.64, 0.024, 0.026, 0, 0.44, 0.14, accentMaterial(0.9, 0.28), 0.08);
    }

    const glow = new THREE.Sprite(
      new THREE.SpriteMaterial({
        map: createGlowTexture(THREE, color),
        transparent: true,
        opacity: 0.11,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
    glow.scale.set(1.65, 0.96, 1);
    glow.position.y = -0.42;
    group.add(glow);

    const beacon = new THREE.Mesh(
      new THREE.CylinderGeometry(0.014, 0.018, 1.38, 24),
      new THREE.MeshBasicMaterial({
        color: accentColor,
        transparent: true,
        opacity: 0.1,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
    beacon.position.y = 0.16;
    group.add(beacon);

    const panel = new THREE.Mesh(
      new THREE.PlaneGeometry(2.68, 0.84),
      new THREE.MeshBasicMaterial({
        color: panelColor,
        transparent: true,
        opacity: 0.28,
        side: THREE.DoubleSide,
        depthTest: false,
        depthWrite: false
      })
    );
    panel.position.set(0, -1.04, 0.42);
    panel.renderOrder = 16;
    group.add(panel);

    const label = new THREE.Sprite(
      new THREE.SpriteMaterial({
        map: createLabelTexture(THREE, module.number, module.shortTitle, color),
        transparent: true,
        opacity: 0.56,
        depthTest: false,
        depthWrite: false
      })
    );
    label.position.set(0, -1.04, 0.52);
    label.scale.set(2.62, 0.84, 1);
    label.renderOrder = 18;
    group.add(label);

    const light = new THREE.PointLight(accentColor, 0.18, 3.2);
    light.position.set(0, 0.2, 0);
    group.add(light);

    return { group, visual, glow, beacon, panel, label, light, materials, index };
  }

  function createDetailCard(THREE, module, color, index, total, presenter, portraitImage) {
    const group = new THREE.Group();
    const backing = new THREE.Mesh(
      new THREE.BoxGeometry(5.82, 4.3, 0.05),
      new THREE.MeshBasicMaterial({
        color: 0x26566a,
        transparent: true,
        opacity: 0.2,
        depthTest: false,
        depthWrite: false
      })
    );
    group.add(backing);

    const face = new THREE.Mesh(
      new THREE.PlaneGeometry(5.78, 4.26),
      new THREE.MeshBasicMaterial({
        map: createDetailCardTexture(THREE, module, color, index, total, presenter, portraitImage),
        transparent: true,
        opacity: 0.98,
        depthTest: false,
        depthWrite: false
      })
    );
    face.position.z = 0.08;
    group.add(face);

    const rail = new THREE.Mesh(
      new THREE.PlaneGeometry(4.35, 0.045),
      new THREE.MeshBasicMaterial({
        color: 0xffffff,
        transparent: true,
        opacity: 0.16,
        depthTest: false,
        depthWrite: false
      })
    );
    rail.position.set(0, -1.68, 0.12);
    group.add(rail);

    const fill = new THREE.Mesh(
      new THREE.PlaneGeometry(4.35, 0.07),
      new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity: 0.95,
        depthTest: false,
        depthWrite: false,
        blending: THREE.AdditiveBlending
      })
    );
    fill.position.set(-2.175, -1.68, 0.13);
    fill.scale.x = 0.001;
    group.add(fill);

    const accents = [
      { x: -2.82, y: 2.12, w: 0.85, h: 0.025 },
      { x: 2.32, y: -2.12, w: 0.85, h: 0.025 },
      { x: -2.82, y: -2.12, w: 0.025, h: 0.65 },
      { x: 2.82, y: 2.12, w: 0.025, h: 0.65 }
    ];
    accents.forEach((accent) => {
      const mesh = new THREE.Mesh(
        new THREE.PlaneGeometry(accent.w, accent.h),
        new THREE.MeshBasicMaterial({
          color,
          transparent: true,
          opacity: 0.7,
          depthTest: false,
          depthWrite: false,
          blending: THREE.AdditiveBlending
        })
      );
      mesh.position.set(accent.x, accent.y, 0.14);
      mesh.renderOrder = 20;
      group.add(mesh);
    });
    group.renderOrder = 20;
    backing.renderOrder = 20;
    face.renderOrder = 20;
    rail.renderOrder = 20;
    fill.renderOrder = 20;

    return {
      group,
      update(nextModule, nextColor, nextIndex, nextTotal, nextPresenter, nextPortraitImage) {
        const nextTexture = createDetailCardTexture(THREE, nextModule, nextColor, nextIndex, nextTotal, nextPresenter, nextPortraitImage);
        face.material.map?.dispose();
        face.material.map = nextTexture;
        face.material.needsUpdate = true;
        fill.material.color.setHex(nextColor);
      },
      updateProgress(value) {
        const progress = Math.max(0.001, Math.min(1, value));
        fill.scale.x = progress;
        fill.position.x = -2.175 + 2.175 * progress;
      }
    };
  }

  function createDetailCardTexture(THREE, module, color, index, total, presenter, portraitImage) {
    const canvas = document.createElement('canvas');
    canvas.width = 1280;
    canvas.height = 960;
    const ctx = canvas.getContext('2d');
    const accent = `#${color.toString(16).padStart(6, '0')}`;
    const panelGradient = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
    panelGradient.addColorStop(0, 'rgba(28, 73, 91, 0.88)');
    panelGradient.addColorStop(0.55, 'rgba(18, 62, 78, 0.68)');
    panelGradient.addColorStop(1, 'rgba(13, 42, 58, 0.74)');

    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = panelGradient;
    roundRect(ctx, 28, 28, 1224, 904, 34);
    ctx.fill();
    ctx.strokeStyle = 'rgba(177, 246, 255, 0.46)';
    ctx.lineWidth = 2;
    ctx.stroke();

    ctx.fillStyle = 'rgba(177, 246, 255, 0.08)';
    roundRect(ctx, 52, 52, 1176, 856, 26);
    ctx.fill();

    ctx.fillStyle = accent;
    ctx.font = '900 31px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText('全息模块信息板', 86, 118);
    ctx.fillStyle = '#ffffff';
    ctx.font = '950 58px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.textAlign = 'right';
    ctx.fillText(`${module.number}`, 1110, 124);
    ctx.fillStyle = 'rgba(255, 255, 255, 0.42)';
    ctx.font = '900 52px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(`/${String(total).padStart(2, '0')}`, 1200, 124);
    ctx.textAlign = 'left';

    ctx.fillStyle = 'rgba(255, 255, 255, 0.12)';
    roundRect(ctx, 86, 170, 430, 116, 22);
    ctx.fill();
    if (portraitImage?.complete) {
      ctx.save();
      roundRect(ctx, 106, 190, 76, 76, 16);
      ctx.clip();
      ctx.drawImage(portraitImage, 106, 190, 76, 76);
      ctx.restore();
    } else {
      ctx.fillStyle = 'rgba(125, 227, 239, 0.26)';
      roundRect(ctx, 106, 190, 76, 76, 16);
      ctx.fill();
      ctx.fillStyle = '#eafcff';
      ctx.font = '900 28px "PingFang SC", "Microsoft YaHei", sans-serif';
      ctx.fillText('张', 130, 238);
    }
    ctx.fillStyle = '#ffffff';
    ctx.font = '900 33px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(presenter.name, 204, 222);
    ctx.fillStyle = 'rgba(255, 255, 255, 0.68)';
    ctx.font = '700 23px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(presenter.role, 204, 258);

    const iconGradient = ctx.createLinearGradient(86, 342, 222, 478);
    iconGradient.addColorStop(0, '#f3d98a');
    iconGradient.addColorStop(1, '#7de3ef');
    ctx.fillStyle = iconGradient;
    roundRect(ctx, 86, 344, 142, 142, 22);
    ctx.fill();
    ctx.fillStyle = '#06101e';
    ctx.font = '950 64px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(module.icon, 157, 434);
    ctx.textAlign = 'left';

    ctx.fillStyle = accent;
    ctx.font = '900 26px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(`模块 ${module.number}`, 270, 364);
    ctx.fillStyle = '#ffffff';
    ctx.font = '950 68px "PingFang SC", "Microsoft YaHei", sans-serif';
    drawWrappedText(ctx, module.title, 270, 438, 860, 72, 2);

    ctx.fillStyle = 'rgba(255, 255, 255, 0.86)';
    ctx.font = '750 39px "PingFang SC", "Microsoft YaHei", sans-serif';
    drawWrappedText(ctx, module.text, 86, 596, 1080, 58, 4);

    let tagX = 86;
    ctx.font = '800 24px "PingFang SC", "Microsoft YaHei", sans-serif';
    module.tags.forEach((tag) => {
      const width = Math.min(300, Math.ceil(ctx.measureText(tag).width) + 52);
      drawPill(ctx, tag, tagX, 790, width, 52, accent);
      tagX += width + 20;
    });

    ctx.strokeStyle = 'rgba(177, 246, 255, 0.24)';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(86, 874);
    ctx.lineTo(1190, 874);
    ctx.stroke();

    ctx.fillStyle = 'rgba(255, 255, 255, 0.5)';
    ctx.font = '800 22px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(module.summary, 86, 918);

    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    return texture;
  }

  function drawPill(ctx, text, x, y, width, height, accent) {
    ctx.fillStyle = 'rgba(125, 227, 239, 0.16)';
    ctx.strokeStyle = 'rgba(125, 227, 239, 0.38)';
    ctx.lineWidth = 2;
    roundRect(ctx, x, y, width, height, height / 2);
    ctx.fill();
    ctx.stroke();
    ctx.fillStyle = '#eafcff';
    ctx.font = '800 24px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(text, x + 26, y + 34);
    ctx.fillStyle = accent;
    ctx.beginPath();
    ctx.arc(x + width - 24, y + height / 2, 5, 0, Math.PI * 2);
    ctx.fill();
  }

  function drawWrappedText(ctx, text, x, y, maxWidth, lineHeight, maxLines) {
    let line = '';
    let lineCount = 0;
    const chars = Array.from(text);

    for (let index = 0; index < chars.length; index += 1) {
      const testLine = line + chars[index];
      if (ctx.measureText(testLine).width > maxWidth && line) {
        ctx.fillText(line, x, y);
        y += lineHeight;
        line = chars[index];
        lineCount += 1;
        if (lineCount >= maxLines - 1) {
          const rest = chars.slice(index + 1).join('');
          let finalLine = line + rest;
          while (ctx.measureText(`${finalLine}…`).width > maxWidth && finalLine.length > 0) {
            finalLine = finalLine.slice(0, -1);
          }
          ctx.fillText(`${finalLine}…`, x, y);
          return;
        }
      } else {
        line = testLine;
      }
    }

    if (line) ctx.fillText(line, x, y);
  }

  function createSignalField(THREE) {
    const group = new THREE.Group();
    const materials = [
      new THREE.LineBasicMaterial({ color: 0x7de3ef, transparent: true, opacity: 0.075, blending: THREE.AdditiveBlending }),
      new THREE.LineBasicMaterial({ color: 0xf3d98a, transparent: true, opacity: 0.052, blending: THREE.AdditiveBlending })
    ];

    for (let band = 0; band < 4; band += 1) {
      const points = [];
      const radius = 5.1 + band * 1.28;
      for (let step = 0; step < 148; step += 1) {
        const t = (step / 147) * Math.PI * 2.04 + band * 0.55;
        points.push(new THREE.Vector3(
          Math.cos(t) * radius,
          -2.9 + Math.sin(t * 1.4 + band) * 0.08 + band * 0.02,
          Math.sin(t) * radius * 0.58
        ));
      }
      group.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(points), materials[band % materials.length]));
    }

    for (let beam = 0; beam < 8; beam += 1) {
      const angle = (beam / 8) * Math.PI * 2;
      const radius = 5.4 + (beam % 3) * 1.8;
      const x = Math.cos(angle) * radius;
      const z = Math.sin(angle) * radius * 0.7;
      const geometry = new THREE.BufferGeometry().setFromPoints([
        new THREE.Vector3(x, -2.8, z),
        new THREE.Vector3(x * 0.8, 2.6 + (beam % 2) * 0.46, z * 0.8)
      ]);
      group.add(new THREE.Line(geometry, materials[beam % materials.length]));
    }

    return group;
  }

  function createLabelTexture(THREE, number, title, color) {
