---
import { societyModules } from '../data/society';

const sceneModules = societyModules.map(({ number, shortTitle, title }) => ({
  number,
  shortTitle,
  title
}));
---

<div class="compute-scene" data-compute-scene data-compute-modules={JSON.stringify(sceneModules)} aria-hidden="true">
  <canvas data-compute-canvas></canvas>
  <div class="compute-scene__overlay"></div>
</div>

<script>
  const roots = document.querySelectorAll('[data-compute-scene]');

  if (roots.length > 0) {
    import('three').then((THREE) => {
      roots.forEach((root) => initScene(THREE, root));
    });
  }

  function initScene(THREE, root) {
    const canvas = root.querySelector('[data-compute-canvas]');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const modules = JSON.parse(root.dataset.computeModules || '[]');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
      preserveDrawingBuffer: true,
      powerPreference: 'high-performance'
    });

    renderer.setClearColor(0x000000, 0);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.7));

    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x06101e, 0.045);

    const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 140);
    camera.position.set(0, 8.8, 21.5);

    const stage = new THREE.Group();
    const moduleLayer = new THREE.Group();
    const terrainLayer = new THREE.Group();
    const flowLayer = new THREE.Group();
    scene.add(stage);
    stage.add(terrainLayer, moduleLayer, flowLayer);

    const palette = [0x7de3ef, 0xf3d98a, 0x74f0a7, 0xaec7ff, 0xffcc8a];
    const moduleObjects = [];
    const radialLinks = [];
    const orbitRadius = 5.6;
    const orbitAngles = [-Math.PI * 0.55, -Math.PI * 0.15, Math.PI * 0.22, Math.PI * 0.62, Math.PI * 1.02];

    const hub = createHub(THREE);
    hub.position.set(0, 0.75, 0);
    moduleLayer.add(hub);

    modules.forEach((module, index) => {
      const angle = orbitAngles[index] ?? (index / Math.max(1, modules.length)) * Math.PI * 2;
      const position = new THREE.Vector3(
        Math.cos(angle) * orbitRadius,
        1.12 + Math.sin(index * 1.7) * 0.46,
        Math.sin(angle) * orbitRadius * 0.78
      );
      const moduleObject = createModulePod(THREE, module, index, palette[index % palette.length]);
      moduleObject.group.position.copy(position);
      moduleObject.group.lookAt(hub.position);
      moduleLayer.add(moduleObject.group);
      moduleObjects.push({ ...moduleObject, position, angle });

      const curve = new THREE.CatmullRomCurve3([
        hub.position.clone(),
        new THREE.Vector3(position.x * 0.46, position.y + 1.25, position.z * 0.5),
        position.clone()
      ]);
      const line = new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(curve.getPoints(80)),
        new THREE.LineBasicMaterial({
          color: palette[index % palette.length],
          transparent: true,
          opacity: 0.24
        })
      );
      radialLinks.push({ curve, line });
      flowLayer.add(line);
    });

    const externalSources = [
      new THREE.Vector3(-11.4, 0.3, -6.5),
      new THREE.Vector3(-10.2, 2.1, 2.4),
      new THREE.Vector3(10.8, 1.1, -4.8),
      new THREE.Vector3(9.5, 2.7, 4.1)
    ];

    externalSources.forEach((source, index) => {
      const sourceNode = new THREE.Mesh(
        new THREE.IcosahedronGeometry(0.18, 1),
        new THREE.MeshBasicMaterial({
          color: index < 2 ? 0x7de3ef : 0xf3d98a,
          transparent: true,
          opacity: 0.72
        })
      );
      sourceNode.position.copy(source);
      flowLayer.add(sourceNode);

      const curve = new THREE.CatmullRomCurve3([
        source,
        new THREE.Vector3(source.x * 0.42, 2.4 + index * 0.18, source.z * 0.32),
        hub.position.clone()
      ]);
      const line = new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(curve.getPoints(90)),
        new THREE.LineBasicMaterial({
          color: index < 2 ? 0x7de3ef : 0xf3d98a,
          transparent: true,
          opacity: 0.16
        })
      );
      radialLinks.push({ curve, line });
      flowLayer.add(line);
    });

    createTerrain(THREE, terrainLayer);

    const particles = createFlowParticles(THREE, radialLinks, 64);
    particles.forEach((particle) => flowLayer.add(particle.mesh));

    const stars = createStars(THREE);
    stage.add(stars);

    let activeIndex = 0;
    let targetRotation = 0.2;
    let frameId = 0;
    const clock = new THREE.Clock();
    const lookTarget = new THREE.Vector3(0, 0.5, 0);

    function setActive(index) {
      activeIndex = (index + moduleObjects.length) % moduleObjects.length;
      const active = moduleObjects[activeIndex];
      targetRotation = Math.PI * 0.12 - active.angle;
      root.dataset.activeModule = String(activeIndex);
    }

    function handleModuleChange(event) {
      if (!event.detail || typeof event.detail.index !== 'number') return;
      setActive(event.detail.index);
    }

    window.addEventListener('society:module-change', handleModuleChange);
    setActive(0);

    function resize() {
      const rect = root.getBoundingClientRect();
      const width = Math.max(1, Math.floor(rect.width));
      const height = Math.max(1, Math.floor(rect.height));
      renderer.setSize(width, height, false);
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
    }

    function render() {
      const elapsed = clock.getElapsedTime();
      stage.rotation.y += (targetRotation - stage.rotation.y) * 0.028;
      stage.rotation.x = Math.sin(elapsed * 0.16) * 0.025;
      terrainLayer.position.x = Math.sin(elapsed * 0.22) * 0.3;
      stars.rotation.y = elapsed * 0.02;

      const active = moduleObjects[activeIndex];
      lookTarget.set(active.position.x * 0.2, 0.75, active.position.z * 0.1);
      camera.position.x += (active.position.x * 0.12 - camera.position.x) * 0.012;
      camera.lookAt(lookTarget);

      moduleObjects.forEach((moduleObject, index) => {
        const isActive = index === activeIndex;
        const pulse = 1 + Math.sin(elapsed * 2.2 + index) * 0.035;
        const baseScale = isActive ? 1.32 : 0.92;
        moduleObject.group.scale.setScalar(baseScale * pulse);
        moduleObject.ring.material.opacity = isActive ? 0.82 : 0.28;
        moduleObject.core.material.opacity = isActive ? 0.96 : 0.52;
        moduleObject.label.material.opacity = isActive ? 0.98 : 0.42;
        moduleObject.panel.material.opacity = isActive ? 0.36 : 0.12;
        moduleObject.group.rotation.y += isActive ? 0.006 : 0.002;
      });

      hub.rotation.y -= 0.01;
      hub.rotation.z = Math.sin(elapsed * 0.6) * 0.12;

      particles.forEach((particle) => {
        const curve = particle.curve;
        const t = (elapsed * particle.speed + particle.offset) % 1;
        particle.mesh.position.copy(curve.getPointAt(t));
        particle.mesh.scale.setScalar(particle.baseScale * (0.8 + Math.sin(t * Math.PI * 2) * 0.25));
      });

      renderer.render(scene, camera);
      if (!prefersReducedMotion.matches) frameId = window.requestAnimationFrame(render);
    }

    const observer = new ResizeObserver(resize);
    observer.observe(root);
    resize();

    if (prefersReducedMotion.matches) {
      renderer.render(scene, camera);
    } else {
      frameId = window.requestAnimationFrame(render);
    }

    prefersReducedMotion.addEventListener?.('change', () => {
      window.cancelAnimationFrame(frameId);
      clock.start();
      resize();
      render();
    });

    window.addEventListener('pagehide', () => {
      observer.disconnect();
      window.removeEventListener('society:module-change', handleModuleChange);
      window.cancelAnimationFrame(frameId);
      renderer.dispose();
      scene.traverse((object) => {
        if (object.geometry) object.geometry.dispose();
        if (object.material) {
          const materials = Array.isArray(object.material) ? object.material : [object.material];
          materials.forEach((material) => {
            if (material.map) material.map.dispose();
            material.dispose();
          });
        }
      });
    }, { once: true });
  }

  function createHub(THREE) {
    const group = new THREE.Group();
    const core = new THREE.Mesh(
      new THREE.IcosahedronGeometry(0.72, 2),
      new THREE.MeshBasicMaterial({
        color: 0xf3d98a,
        transparent: true,
        opacity: 0.92
      })
    );
    group.add(core);

    const rings = [
      new THREE.TorusGeometry(1.25, 0.018, 16, 96),
      new THREE.TorusGeometry(1.68, 0.012, 16, 96),
      new THREE.TorusGeometry(2.08, 0.01, 16, 96)
    ];

    rings.forEach((geometry, index) => {
      const ring = new THREE.Mesh(
        geometry,
        new THREE.MeshBasicMaterial({
          color: index === 0 ? 0xf3d98a : 0x7de3ef,
          transparent: true,
          opacity: 0.34 - index * 0.07
        })
      );
      ring.rotation.x = Math.PI / 2 + index * 0.2;
      ring.rotation.y = index * 0.55;
      group.add(ring);
    });

    return group;
  }

  function createModulePod(THREE, module, index, color) {
    const group = new THREE.Group();
    const core = new THREE.Mesh(
      new THREE.OctahedronGeometry(0.46, 1),
      new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity: 0.72
      })
    );
    group.add(core);

    const ring = new THREE.Mesh(
      new THREE.TorusGeometry(0.95, 0.025, 18, 96),
      new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity: 0.36
      })
    );
    ring.rotation.x = Math.PI / 2.4;
    group.add(ring);

    const panel = new THREE.Mesh(
      new THREE.PlaneGeometry(2.9, 1.05),
      new THREE.MeshBasicMaterial({
        color: 0x081a29,
        transparent: true,
        opacity: 0.16,
        side: THREE.DoubleSide
      })
    );
    panel.position.set(0, -0.95, 0.1);
    group.add(panel);

    const label = new THREE.Sprite(
      new THREE.SpriteMaterial({
        map: createLabelTexture(THREE, module.number, module.shortTitle, color),
        transparent: true,
        opacity: 0.56,
        depthWrite: false
      })
    );
    label.position.set(0, -0.95, 0.18);
    label.scale.set(2.85, 1.02, 1);
    group.add(label);

    return { group, core, ring, panel, label, index };
  }

  function createLabelTexture(THREE, number, title, color) {
    const canvas = document.createElement('canvas');
    canvas.width = 512;
    canvas.height = 184;
    const ctx = canvas.getContext('2d');
    const accent = `#${color.toString(16).padStart(6, '0')}`;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = 'rgba(6, 16, 30, 0.62)';
    ctx.strokeStyle = 'rgba(125, 227, 239, 0.42)';
    ctx.lineWidth = 3;
    roundRect(ctx, 10, 10, 492, 164, 18);
    ctx.fill();
    ctx.stroke();
    ctx.fillStyle = accent;
    ctx.font = '700 30px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(number, 38, 66);
    ctx.fillStyle = '#ffffff';
    ctx.font = '900 48px "PingFang SC", "Microsoft YaHei", sans-serif';
    ctx.fillText(title, 38, 128);
    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    return texture;
  }

  function roundRect(ctx, x, y, width, height, radius) {
    ctx.beginPath();
    ctx.moveTo(x + radius, y);
    ctx.arcTo(x + width, y, x + width, y + height, radius);
    ctx.arcTo(x + width, y + height, x, y + height, radius);
    ctx.arcTo(x, y + height, x, y, radius);
    ctx.arcTo(x, y, x + width, y, radius);
    ctx.closePath();
  }

  function createTerrain(THREE, terrainLayer) {
    terrainLayer.position.y = -3.45;
    const gold = new THREE.LineBasicMaterial({ color: 0xd7a43a, transparent: true, opacity: 0.34 });
    const cyan = new THREE.LineBasicMaterial({ color: 0x55dbea, transparent: true, opacity: 0.2 });

    for (let row = 0; row < 13; row += 1) {
      const points = [];
      const z = -10.5 + row * 1.7;
      for (let i = 0; i < 128; i += 1) {
        const x = -15 + i * 0.24;
        const y = Math.sin(i * 0.17 + row * 0.7) * 0.16 + Math.cos(i * 0.05 + row) * 0.26;
        points.push(new THREE.Vector3(x, y, z + Math.sin(i * 0.06) * 0.22));
      }
      terrainLayer.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(points), row % 4 === 0 ? cyan : gold));
    }

    const grid = new THREE.GridHelper(32, 32, 0x42d9e8, 0x42d9e8);
    grid.position.y = -0.2;
    grid.material.transparent = true;
    grid.material.opacity = 0.12;
    terrainLayer.add(grid);
  }

  function createFlowParticles(THREE, links, count) {
    const particles = [];
    const geometry = new THREE.SphereGeometry(0.065, 12, 12);
    const materials = [
      new THREE.MeshBasicMaterial({ color: 0xf3d98a }),
      new THREE.MeshBasicMaterial({ color: 0x7de3ef }),
      new THREE.MeshBasicMaterial({ color: 0x74f0a7 })
    ];

    for (let index = 0; index < count; index += 1) {
      const link = links[index % links.length];
      const mesh = new THREE.Mesh(geometry, materials[index % materials.length]);
      particles.push({
        mesh,
        curve: link.curve,
        offset: index / count,
        speed: 0.045 + (index % 8) * 0.007,
        baseScale: 0.75 + (index % 5) * 0.08
      });
    }
    return particles;
  }

  function createStars(THREE) {
    const geometry = new THREE.BufferGeometry();
    const positions = [];
    for (let i = 0; i < 360; i += 1) {
      positions.push((Math.random() - 0.5) * 38, Math.random() * 18 - 1.5, (Math.random() - 0.5) * 28);
    }
    geometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
    return new THREE.Points(
      geometry,
      new THREE.PointsMaterial({
        color: 0x7de3ef,
        size: 0.035,
        transparent: true,
        opacity: 0.48
      })
    );
  }
</script>
