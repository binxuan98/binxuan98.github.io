---
const screenUrl = '/exhibition/qingyang-screen3/index.html';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="庆阳职业技术学院数字信息系产学研协同独立展示页面。" />
    <meta name="theme-color" content="#faf9f5" />
    <title>产学研协同 | 数字信息系服务庆阳算力产业</title>
    <style>
      html,
      body {
        width: 100%;
        height: 100%;
        margin: 0;
        overflow: hidden;
        background: #faf9f5;
      }

      iframe {
        position: fixed;
        inset: 0;
        display: block;
        width: 100%;
        height: 100%;
        border: 0;
        background: #faf9f5;
      }
    </style>
  </head>
  <body>
    <iframe
      src={screenUrl}
      title="庆阳职业技术学院数字信息系产学研协同展示"
      loading="eager"
      fetchpriority="high"
      allowfullscreen
    ></iframe>
    <noscript>
      <a href={screenUrl}>打开产学研协同展示</a>
    </noscript>
  </body>
</html>
