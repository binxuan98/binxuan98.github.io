---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import MetricGrid from '../components/MetricGrid.astro';
import ProfilePortrait from '../components/ProfilePortrait.astro';
import ProjectList from '../components/ProjectList.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TagRow from '../components/TagRow.astro';
import shanshui from '../assets/images/shanshui.jpg';
import { capabilityRows, focusAreas, metrics, profile, projects } from '../data/profile';
---

<BaseLayout title="张斌轩 | AI 研究与教育实践" bodyClass="home-page">
  <section class="brand-hero">
    <div class="hero-copy">
      <p class="hero-line">AI Research · Education Practice · Computing Power</p>
      <h1>{profile.name}</h1>
      <p class="hero-en">{profile.englishName}</p>
      <p class="hero-title">{profile.title}</p>
      <p class="hero-lead">{profile.summary}</p>
      <div class="hero-actions">
        <a class="button-primary" href="/qingyang-screen3/">高天厚土·福地庆阳</a>
        <a class="button-secondary" href="/society/">查看智研社展厅</a>
        <a class="button-secondary" href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
      </div>
      <MetricGrid items={metrics} className="hero-proof" />
    </div>

    <ProfilePortrait />
  </section>

  <section id="work" class="content-band">
    <SectionHeading
      eyebrow="Research Focus"
      title="把人工智能研究做成能被看见、能被学习、能被实践的能力。"
      text={profile.headline}
    />
    <div class="focus-grid">
      {focusAreas.map((area) => (
        <article class="focus-card">
          <h3>{area.title}</h3>
          <p>{area.text}</p>
          <TagRow tags={area.tags} />
        </article>
      ))}
    </div>
  </section>

  <section class="capability-section" aria-label="能力矩阵">
    <div class="capability-shell">
      <span>Capability Matrix</span>
      <div>
        {capabilityRows.map(([label, text]) => (
          <article>
            <strong>{label}</strong>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="projects" class="feature-section">
    <div class="feature-media" aria-hidden="true">
      <Image src={shanshui} alt="" widths={[640, 960, 1280]} sizes="(max-width: 1180px) 100vw, 42vw" loading="lazy" />
    </div>
    <div class="feature-copy">
      <span>Selected Work</span>
      <h2>研究、项目和教学在同一个方向上汇合。</h2>
      <ProjectList projects={projects} />
    </div>
  </section>

  <section class="society-preview" aria-label="庆阳职业技术学院智研社">
    <div>
      <span>Qingyang Vocational & Technical College</span>
      <h2>庆阳职业技术学院智研社</h2>
      <p>
        面向领导与企业来访展示，首屏汇报人工智能通识课程、学生培养、重点实验室项目牵引、前沿实践方向与东数西算人才培养主线。
      </p>
    </div>
    <div class="society-preview-actions">
      <a class="button-primary" href="/qingyang-screen3/">高天厚土·福地庆阳</a>
      <a class="button-secondary" href="/society/">进入动态展厅</a>
    </div>
  </section>

  <section id="contact" class="contact-panel">
    <div>
      <span>Contact</span>
      <h2>欢迎交流人工智能研究、项目实践与职业教育合作。</h2>
    </div>
    <div class="contact-links">
      <a href={`mailto:${profile.email}`}>Email</a>
      <a href={profile.scholar} target="_blank" rel="noreferrer">Google Scholar</a>
      <a href={profile.orcid} target="_blank" rel="noreferrer">ORCID</a>
    </div>
  </section>
</BaseLayout>
