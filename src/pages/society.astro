---
import BaseLayout from '../layouts/BaseLayout.astro';
import MetricGrid from '../components/MetricGrid.astro';
import SocietyBriefingStrip from '../components/SocietyBriefingStrip.astro';
import SocietyCarousel from '../components/SocietyCarousel.astro';
import ThreeComputeScene from '../components/ThreeComputeScene.astro';
import { societyMetrics } from '../data/society';
---

<BaseLayout
  title="庆阳职业技术学院智研社"
  description="庆阳职业技术学院智研社动态展厅大屏，展示人工智能通识课程、学生培养、重点实验室项目牵引、前沿实践与东数西算人才培养。"
  bodyClass="society-page"
  presentation={true}
  enableCarousel={true}
>
  <section class="society-screen terrain-grid-bg">
    <ThreeComputeScene />
    <div class="society-shell">
      <div class="society-main">
        <div class="qingyang-logo">高天厚土·福地庆阳</div>
        <h1>
          <span>庆阳职业技术学院</span>
          <strong>智研社</strong>
        </h1>
        <p class="society-subtitle">
          <span>人工智能通识课程</span>
          <span>前沿项目实践</span>
          <span>东数西算人才培养</span>
        </p>
        <p class="society-lead">
          以全校人工智能通识课程为入口，发现并吸纳对 AI 感兴趣的学生；以重点实验室真实项目为牵引，把大模型、AI4S、异构算力调度等前沿工作转化为学生可参与、可理解、可成长的实践任务。
        </p>

        <MetricGrid items={societyMetrics} className="society-metrics" />
      </div>

      <SocietyCarousel />
      <div class="sandbox-caption" aria-hidden="true">
        <span>3D 数据沙盘</span>
        <strong>课程 · 社团 · 项目 · 算力</strong>
      </div>
      <SocietyBriefingStrip />
    </div>
  </section>
</BaseLayout>
