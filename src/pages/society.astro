---
import BaseLayout from '../layouts/BaseLayout.astro';
import MetricGrid from '../components/MetricGrid.astro';
import QingyangComputeScene from '../components/QingyangComputeScene.astro';
import SocietyCarousel from '../components/SocietyCarousel.astro';
import ThreeComputeScene from '../components/ThreeComputeScene.astro';
import { qingyangMetrics, qingyangStory } from '../data/qingyang';
import { societyMetrics } from '../data/society';
---

<BaseLayout
  title="庆阳职业技术学院智研社"
  description="庆阳职业技术学院智研社动态展厅大屏，展示人工智能通识课程、学生培养、重点实验室项目牵引、前沿实践与东数西算人才培养。"
  bodyClass="society-page"
  presentation={true}
  enableCarousel={true}
>
  <section class="qingyang-compute-screen qingyang-grid-bg">
    <QingyangComputeScene />
    <div class="compute-hero-shell">
      <div class="compute-hero-copy">
        <div class="qingyang-logo">{qingyangStory.badge}</div>
        <h1>
          <span>东数西算</span>
          <strong>庆阳枢纽</strong>
        </h1>
        <p class="compute-hero-lead">{qingyangStory.subtitle}</p>
        <p class="compute-hero-proof">{qingyangStory.proof}</p>
        <MetricGrid items={qingyangMetrics} className="compute-hero-metrics" />
      </div>

      <a class="screen-scroll-cue" href="#society-cultivation" aria-label="向下进入智研社人才培养沙盘">
        <span>向下进入</span>
        <strong>智研社人才培养沙盘</strong>
      </a>
    </div>
  </section>

  <section class="society-screen terrain-grid-bg" id="society-cultivation">
    <ThreeComputeScene />
    <div class="society-shell">
      <div class="society-main">
        <div class="qingyang-logo">高天厚土·福地庆阳</div>
        <h1>
          <span>庆阳职业技术学院</span>
          <strong>智研社</strong>
        </h1>
        <p class="society-subtitle">
          <span>人工智能通识课程</span>
          <span>前沿项目实践</span>
          <span>东数西算人才培养</span>
        </p>
        <p class="society-lead">
          以全校人工智能通识课程为入口，发现并吸纳对 AI 感兴趣的学生；以重点实验室真实项目为牵引，把大模型、AI4S、异构算力调度等前沿工作转化为学生可参与、可理解、可成长的实践任务。
        </p>

        <MetricGrid items={societyMetrics} className="society-metrics" />
      </div>

      <SocietyCarousel />

      <p class="society-mission">
        为建设繁荣富庶、产业崛起、活力迸发、绿色转型、幸福美好新庆阳贡献职教力量。
      </p>
    </div>
  </section>
</BaseLayout>
