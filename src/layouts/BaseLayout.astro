---
import '../styles/global.css';

const {
  title = '张斌轩 | Binxuan Zhang',
  description = '张斌轩的个人品牌站，聚焦人工智能、计算机视觉、大语言模型、RAG 与职业教育实践。',
  bodyClass = '',
  presentation = false
} = Astro.props;

const pageTitle = title.includes('张斌轩') || title.includes('Binxuan')
  ? title
  : `${title} | 张斌轩`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07111f" />
    <title>{pageTitle}</title>
    <link rel="icon" href="/images/site-logo.png" />
  </head>
  <body class={bodyClass}>
    {!presentation && (
      <header class="site-header" data-site-header>
        <a class="brand-mark" href="/" aria-label="返回首页">
          <span>BX</span>
          <strong>张斌轩</strong>
        </a>
        <nav class="site-nav" aria-label="主导航">
          <a href="/#work">研究方向</a>
          <a href="/#projects">项目实践</a>
          <a href="/society/">智研社</a>
          <a href="/#contact">联系</a>
        </nav>
      </header>
    )}
    <main>
      <slot />
    </main>
    {!presentation && (
      <footer class="site-footer">
        <span>© {new Date().getFullYear()} Binxuan Zhang</span>
        <a href="mailto:zhangbinxuan98@foxmail.com">zhangbinxuan98@foxmail.com</a>
      </footer>
    )}
    <script src="/scripts/site.js" defer></script>
  </body>
</html>
