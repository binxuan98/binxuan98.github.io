---
import '../styles/global.css';
import { navItems, profile } from '../data/profile';

const {
  title = '张斌轩 | Binxuan Zhang',
  description = '张斌轩的个人品牌站，聚焦人工智能、计算机视觉、大语言模型、RAG 与职业教育实践。',
  bodyClass = '',
  presentation = false,
  enableCarousel = false
} = Astro.props;

const pageTitle = title.includes('张斌轩') || title.includes('Binxuan')
  ? title
  : `${title} | 张斌轩`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07111f" />
    <title>{pageTitle}</title>
    <link rel="icon" href="/images/site-logo.png" />
  </head>
  <body class={bodyClass}>
    {!presentation && (
      <header class="site-header" data-site-header>
        <a class="brand-mark" href="/" aria-label="返回首页">
          <span>BX</span>
          <strong>{profile.name}</strong>
        </a>
        <nav class="site-nav" aria-label="主导航">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </header>
    )}
    <main>
      <slot />
    </main>
    {!presentation && (
      <footer class="site-footer">
        <span>© {new Date().getFullYear()} Binxuan Zhang</span>
        <a href={`mailto:${profile.email}`}>{profile.email}</a>
      </footer>
    )}
    {enableCarousel && <script src="/scripts/site.js" defer></script>}
  </body>
</html>
